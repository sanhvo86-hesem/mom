{
  "$schema": "https://www.designtokens.org/tr/2025.10/format/",
  "$description": "HESEM Lego Foundation — DTCG 2025.10 token source of truth. Seed inputs only; the OKLCH-derived ramps + state variants + semantic aliases are generated by tools/scripts/gen-lego-tokens.mjs into mom/styles/lego-foundation.css. Mirrors graphics_token_catalog (migration 148). Tier 1 = primitive seeds, Tier 2 = semantic aliases, Tier 3 = component (declared in CSS @layer).",
  "color": {
    "$type": "color",
    "seed": {
      "$description": "Tier-1 brand/status seeds. One value each; the generator derives base/hover/active/subtle/border/on-* ramps in OKLCH.",
      "brand":   { "$value": "#1565c0", "$description": "Primary brand" },
      "accent":  { "$value": "#f9a825", "$description": "Accent / highlight" },
      "success": { "$value": "#16a34a" },
      "warning": { "$value": "#d97706" },
      "danger":  { "$value": "#dc2626" },
      "info":    { "$value": "#2563eb" },
      "neutral": { "$value": "#64748b" }
    },
    "surface": {
      "$description": "Tier-2 surface aliases, light/dark pairs (emitted via light-dark()).",
      "page":   { "$value": { "light": "#f1f5f9", "dark": "#0f172a" } },
      "card":   { "$value": { "light": "#ffffff", "dark": "#1e293b" } },
      "raised": { "$value": { "light": "#ffffff", "dark": "#243044" } },
      "muted":  { "$value": { "light": "#f8fafc", "dark": "#172033" } }
    },
    "text": {
      "strong":  { "$value": { "light": "#0f172a", "dark": "#f1f5f9" } },
      "default": { "$value": { "light": "#334155", "dark": "#cbd5e1" } },
      "muted":   { "$value": { "light": "#64748b", "dark": "#94a3b8" } },
      "inverse": { "$value": { "light": "#ffffff", "dark": "#0f172a" } }
    },
    "border": {
      "subtle":  { "$value": { "light": "#e2e8f0", "dark": "#334155" } },
      "default": { "$value": { "light": "#cbd5e1", "dark": "#475569" } },
      "strong":  { "$value": { "light": "#94a3b8", "dark": "#64748b" } }
    }
  },
  "space": {
    "$type": "dimension",
    "master":  { "$value": { "value": 8, "unit": "px" }, "$description": "99% of gaps (mig 227)" },
    "section": { "$value": { "value": 12, "unit": "px" }, "$description": "Top-level section dividers only" }
  },
  "radius": {
    "$type": "dimension",
    "master": { "$value": { "value": 4, "unit": "px" } },
    "card":   { "$value": { "value": 8, "unit": "px" } },
    "pill":   { "$value": { "value": 999, "unit": "px" } }
  },
  "control": {
    "$type": "dimension",
    "height": {
      "standard": { "$value": { "value": 32, "unit": "px" }, "$description": "Desk density (mig 230)" },
      "cozy":     { "$value": { "value": 44, "unit": "px" }, "$description": "Shop-floor / touch / gloved" }
    }
  },
  "motion": {
    "$type": "duration",
    "fast": { "$value": { "value": 100, "unit": "ms" } },
    "base": { "$value": { "value": 200, "unit": "ms" } },
    "slow": { "$value": { "value": 320, "unit": "ms" } }
  },
  "font": {
    "size": {
      "$type": "dimension",
      "xs":  { "$value": { "value": 11, "unit": "px" } },
      "sm":  { "$value": { "value": 13, "unit": "px" } },
      "md":  { "$value": { "value": 14, "unit": "px" } },
      "lg":  { "$value": { "value": 16, "unit": "px" } },
      "xl":  { "$value": { "value": 20, "unit": "px" } },
      "2xl": { "$value": { "value": 24, "unit": "px" } }
    }
  }
}
