#!/usr/bin/env bash
# Hard refusal: block any commit that touches runtime-mutated files.
# Two categories are protected:
#   1. Runtime config JSON files (mom/data/config/*.json)
#   2. Portal-managed HTML document files (mom/docs/**/*.html)
#
# Both are written at runtime by PHP-FPM / portal editor. Committing a local
# copy of either can silently overwrite live data on the next deploy.
#
# Bypass (only for genuine structural fixes — read the warning carefully):
#   git commit --no-verify

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
RUNTIME_LIST="$REPO_ROOT/tools/vps-setup/scripts/_runtime-files.sh"
if [ -f "$RUNTIME_LIST" ]; then
    # shellcheck source=tools/vps-setup/scripts/_runtime-files.sh
    . "$RUNTIME_LIST"

    # ── Check 1: runtime config JSON files ───────────────────────────────
    OFFENDERS=$(git diff --cached --name-only | grep -E "$RUNTIME_CONFIG_REGEX" || true)
    if [ -n "$OFFENDERS" ]; then
        echo "" >&2
        echo "pre-commit: refusing to commit runtime-mutated config files." >&2
        echo "" >&2
        printf '%s\n' "$OFFENDERS" | sed 's/^/  - /' >&2
        echo "" >&2
        echo "Runtime config belongs on the VPS only. To push edits, use:" >&2
        echo "  bash tools/vps-setup/scripts/data-sync.sh" >&2
        echo "  or  bash tools/vps-setup/scripts/data-push.sh --change-ref CR-XXX" >&2
        echo "" >&2
        echo "Bypass (rare, requires reading README-DATA-SYNC.md first):" >&2
        echo "  git commit --no-verify" >&2
        exit 1
    fi

    # ── Check 2: portal-managed HTML document files ───────────────────────
    # These files are also written at runtime by DocumentController (saveDraft
    # / approve). A local commit overwrites portal-authored content on the VPS
    # because deploy.sh's rsync restore only captures *VPS* pre-deploy state —
    # it cannot recover edits made on your local machine that were never pushed.
    if [ "${ALLOW_DOC_COMMIT:-0}" != "1" ]; then
        DOC_OFFENDERS=$(git diff --cached --name-only | grep -E "$RUNTIME_DOC_REGEX" || true)
        if [ -n "$DOC_OFFENDERS" ]; then
            echo "" >&2
            echo "pre-commit: refusing to commit portal-managed HTML document files." >&2
            echo "" >&2
            printf '%s\n' "$DOC_OFFENDERS" | sed 's/^/  - /' >&2
            echo "" >&2
            echo "These files are written at runtime by the portal document editor." >&2
            echo "Committing a local copy risks overwriting portal-authored edits on" >&2
            echo "the VPS. If you edited this doc in Chrome (localhost), pull the" >&2
            echo "VPS state first:" >&2
            echo "  bash tools/dev-setup/sync-docs-from-vps.sh" >&2
            echo "" >&2
            echo "For a genuine structural/CSS fix (template change, not content):" >&2
            echo "  ALLOW_DOC_COMMIT=1 git commit --no-verify" >&2
            exit 1
        fi
    fi
fi

# Legacy portal encoding check — preserved from prior version of this hook.
if [ -f "$REPO_ROOT/01-QMS-Portal/tools/check_portal_encoding.py" ]; then
    python "$REPO_ROOT/01-QMS-Portal/tools/check_portal_encoding.py" --scope shell
    status=$?
    if [ $status -ne 0 ]; then
        echo ""
        echo "pre-commit: portal encoding audit failed."
        exit $status
    fi
fi

exit 0
