{
  "form_code": "FRM-911",
  "title": "Management Review",
  "title_vi": "Xem xét của lãnh đạo",
  "version": "V1",
  "category": "quality",
  "frequency": "quarterly",
  "sop_ref": "SOP-902",
  "description": "Biên bản xem xét của lãnh đạo theo ISO 9001 điều khoản 9.3, ghi nhận dữ liệu đầu vào, quyết định và hành động.",
  "roles_allowed": ["admin", "ceo", "production_director", "qa_manager"],
  "fields": [
    {"id": "review_date", "type": "date", "label": "Ngày xem xét", "label_en": "Review Date", "required": true, "default": "today"},
    {"id": "review_period_from", "type": "date", "label": "Kỳ xem xét từ", "label_en": "Review Period From", "required": true},
    {"id": "review_period_to", "type": "date", "label": "Kỳ xem xét đến", "label_en": "Review Period To", "required": true},
    {
      "id": "attendees",
      "type": "table",
      "label": "Người tham dự",
      "label_en": "Attendees",
      "min_rows": 1,
      "max_rows": 30,
      "columns": [
        {"id": "name", "type": "text", "label": "Họ tên", "width": "35%", "required": true},
        {"id": "role", "type": "text", "label": "Chức danh", "width": "30%", "required": true},
        {"id": "department", "type": "text", "label": "Phòng ban", "width": "35%"}
      ]
    },
    {
      "id": "agenda_items",
      "type": "table",
      "label": "Chương trình nghị sự",
      "label_en": "Agenda Items",
      "min_rows": 1,
      "max_rows": 20,
      "columns": [
        {"id": "item_number", "type": "text", "label": "#", "width": "8%", "required": true},
        {"id": "topic", "type": "text", "label": "Chủ đề", "width": "60%", "required": true},
        {"id": "presenter", "type": "text", "label": "Người trình bày", "width": "32%"}
      ]
    },
    {
      "id": "input_data",
      "type": "group",
      "label": "Dữ liệu đầu vào (ISO 9001 §9.3.2)",
      "label_en": "Input Data (ISO 9001 §9.3.2)",
      "fields": [
        {"id": "customer_feedback_summary", "type": "textarea", "label": "Tóm tắt phản hồi khách hàng", "rows": 3, "placeholder": "Tổng hợp phản hồi, khiếu nại, khảo sát khách hàng..."},
        {"id": "audit_results_summary", "type": "textarea", "label": "Tóm tắt kết quả đánh giá", "rows": 3, "placeholder": "Kết quả audit nội bộ và bên ngoài..."},
        {"id": "ncr_capa_summary", "type": "textarea", "label": "Tóm tắt NCR/CAPA", "rows": 3, "placeholder": "Số lượng NCR, CAPA, xu hướng..."},
        {"id": "kpi_performance", "type": "textarea", "label": "Hiệu suất KPI", "rows": 3, "placeholder": "OTD, FPY, OEE, COPQ, PPM..."},
        {"id": "process_performance", "type": "textarea", "label": "Hiệu suất quy trình", "rows": 3},
        {"id": "supplier_performance", "type": "textarea", "label": "Hiệu suất nhà cung cấp", "rows": 3},
        {"id": "risk_status", "type": "textarea", "label": "Tình trạng rủi ro & cơ hội", "rows": 3},
        {"id": "improvement_status", "type": "textarea", "label": "Tình trạng cải tiến", "rows": 3},
        {"id": "resource_needs", "type": "textarea", "label": "Nhu cầu nguồn lực", "rows": 3},
        {"id": "change_management", "type": "textarea", "label": "Quản lý thay đổi", "rows": 3}
      ]
    },
    {
      "id": "decisions",
      "type": "table",
      "label": "Quyết định của lãnh đạo",
      "label_en": "Decisions",
      "min_rows": 0,
      "max_rows": 20,
      "columns": [
        {"id": "decision", "type": "text", "label": "Quyết định", "width": "50%", "required": true},
        {"id": "responsible", "type": "text", "label": "Người chịu TN", "width": "25%", "required": true},
        {"id": "target_date", "type": "date", "label": "Ngày mục tiêu", "width": "25%"}
      ]
    },
    {
      "id": "action_items",
      "type": "table",
      "label": "Hành động cần thực hiện",
      "label_en": "Action Items",
      "min_rows": 0,
      "max_rows": 30,
      "columns": [
        {"id": "action", "type": "text", "label": "Hành động", "width": "40%", "required": true},
        {"id": "owner", "type": "text", "label": "Người thực hiện", "width": "20%", "required": true},
        {"id": "due_date", "type": "date", "label": "Hạn hoàn thành", "width": "20%"},
        {"id": "priority", "type": "select", "label": "Ưu tiên", "width": "20%", "options": [
          {"value": "high", "label": "Cao", "color": "#e03131"},
          {"value": "medium", "label": "Trung bình", "color": "#e67700"},
          {"value": "low", "label": "Thấp", "color": "#2f9e44"}
        ]}
      ]
    },
    {"id": "next_review_date", "type": "date", "label": "Ngày xem xét tiếp theo", "label_en": "Next Review Date", "required": true},
    {"id": "minutes_prepared_by", "type": "text", "label": "Người lập biên bản", "label_en": "Minutes Prepared By", "required": true},
    {"id": "approved_by", "type": "text", "label": "Người phê duyệt", "label_en": "Approved By", "required": true}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_submit": ["ceo", "qa_manager", "production_director"]
  }
}
