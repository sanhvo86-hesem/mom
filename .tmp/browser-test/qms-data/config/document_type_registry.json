  "record_types": {
    "NCR": {
      "label": "Non-Conformity Report",
      "label_vi": "Phiếu báo lỗi không phù hợp",
      "description": "Documents any product, process, or system nonconformance requiring disposition and corrective action",
      "form_code": "FRM-631",
      "counter_digits": 3,
      "departments_allowed": ["QA", "PRO", "ENG"],
      "variables": ["job_number", "part_rev", "customer", "defect_type", "disposition", "root_cause"],
      "naming_pattern": "NCR-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Quality-Records/NCR/{YYYY}",
      "online": true,
      "decision_score": 82
    },
    "CAPA": {
      "label": "Corrective Action",
      "label_vi": "Hành động khắc phục phòng ngừa",
      "description": "Corrective and preventive action linked to NCR, audit finding, or customer complaint",
      "form_code": "FRM-641",
      "counter_digits": 3,
      "departments_allowed": ["QA", "PRO", "ENG", "SCM"],
      "variables": ["source_record", "root_cause_method", "action_owner", "target_date", "verification_result"],
      "naming_pattern": "CAPA-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Quality-Records/CAPA/{YYYY}",
      "online": true,
      "decision_score": 78
    },
    "FAI": {
      "label": "First Article Inspection",
      "label_vi": "Kiểm tra sản phẩm đầu tiên",
      "description": "AS9102-compliant first article inspection report for new part, revision, or process change",
      "form_code": "FRM-311",
      "counter_digits": 3,
      "departments_allowed": ["QA", "ENG"],
      "variables": ["part_number", "part_rev", "job_number", "customer", "operation", "measurement_data"],
      "naming_pattern": "FAI-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Quality-Records/FAI/{YYYY}",
      "online": false,
      "decision_score": null
    },
    "TRN": {
      "label": "Training Event",
      "label_vi": "Sự kiện đào tạo",
      "description": "Training session record including attendance, competency assessment, and sign-off",
      "form_code": "FRM-802",
      "counter_digits": 3,
      "departments_allowed": ["HR"],
      "variables": ["training_topic", "trainer", "attendees", "competency_level", "assessment_result"],
      "naming_pattern": "TRN-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/HR-Records/Training/{YYYY}",
      "online": true,
      "decision_score": 72
    },
    "AUD": {
      "label": "Audit",
      "label_vi": "Đánh giá nội bộ / bên ngoài",
      "description": "Internal or external audit finding report with corrective action linkage",
      "form_code": "FRM-913",
      "counter_digits": 3,
      "departments_allowed": ["QA", "EXE"],
      "variables": ["audit_type", "audit_scope", "auditor", "clause_ref", "finding_grade", "capa_link"],
      "naming_pattern": "AUD-{YYYY}-IA{NN}",
      "sharepoint_path": "HESEM-Records/Quality-Records/Audit/{YYYY}",
      "online": true,
      "decision_score": 70
    },
    "ECR": {
      "label": "Engineering Change Request",
      "label_vi": "Yêu cầu thay đổi kỹ thuật",
      "description": "Formal request for engineering change to part, process, tooling, or documentation",
      "form_code": "FRM-161",
      "counter_digits": 3,
      "departments_allowed": ["ENG", "QA"],
      "variables": ["part_number", "change_type", "change_reason", "impact_assessment", "approver"],
      "naming_pattern": "ECR-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Engineering-Records/ECR/{YYYY}",
      "online": false,
      "decision_score": null
    },
    "CAL": {
      "label": "Calibration Record",
      "label_vi": "Hồ sơ hiệu chuẩn",
      "description": "Calibration record for measurement equipment including certificate and result tracking",
      "form_code": "FRM-601",
      "counter_digits": 3,
      "departments_allowed": ["QA"],
      "variables": ["equipment_id", "equipment_type", "cal_standard", "cal_result", "next_due_date"],
      "naming_pattern": "CAL-{EquipCode}-{NNN}",
      "sharepoint_path": "HESEM-Records/Quality-Records/Calibration/{YYYY}",
      "online": true,
      "decision_score": 65
    },
    "SCAR": {
      "label": "Supplier Corrective Action",
      "label_vi": "Hành động khắc phục nhà cung cấp",
      "description": "Supplier corrective action report for incoming quality or delivery nonconformance",
      "form_code": "FRM-403",
      "counter_digits": 3,
      "departments_allowed": ["SCM", "QA"],
      "variables": ["supplier_name", "po_number", "defect_description", "root_cause", "corrective_action"],
      "naming_pattern": "SCAR-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Supply-Chain-Records/SCAR/{YYYY}",
      "online": true,
      "decision_score": 68
    },
    "IMP": {
      "label": "Improvement Project",
      "label_vi": "Dự án cải tiến",
      "description": "Continual improvement project tracked through plan-do-check-act cycle",
      "form_code": null,
      "counter_digits": 3,
      "departments_allowed": ["EXE", "PRO", "QA", "ENG"],
      "variables": ["project_title", "sponsor", "target_kpi", "baseline_value", "target_value", "status"],
      "naming_pattern": "IMP-{YYYY}-{CODE}",
      "sharepoint_path": "HESEM-Records/Improvement-Records/{YYYY}",
      "online": false,
      "decision_score": null
    },
    "MR": {
      "label": "Management Review",
      "label_vi": "Xem xét của lãnh đạo",
      "description": "Periodic management review meeting record per ISO 9001 clause 9.3",
      "form_code": "FRM-911",
      "counter_digits": 2,
      "departments_allowed": ["EXE"],
      "variables": ["review_period", "attendees", "agenda_items", "action_items", "next_review_date"],
      "naming_pattern": "MR-{YYYY}-Q{N}",
      "sharepoint_path": "HESEM-Records/Management-Records/MR/{YYYY}",
      "online": false,
      "decision_score": null
    },
    "RISK": {
      "label": "Risk Review",
      "label_vi": "Đánh giá rủi ro",
      "description": "Risk assessment and review record per ISO 9001 clause 6.1",
      "form_code": "FRM-131",
      "counter_digits": 2,
      "departments_allowed": ["EXE", "QA"],
      "variables": ["risk_category", "likelihood", "severity", "rpn", "mitigation_action", "residual_risk"],
      "naming_pattern": "RISK-{YYYY}-R{NN}",
      "sharepoint_path": "HESEM-Records/Management-Records/Risk/{YYYY}",
      "online": false,
      "decision_score": null
    },
    "DOWNTIME": {
      "label": "Downtime Record",
      "label_vi": "Ghi nhận dừng máy",
      "description": "Machine downtime event record for OEE tracking and maintenance analysis",
      "form_code": "FRM-512",
      "counter_digits": 3,
      "departments_allowed": ["PRO"],
      "variables": ["machine_id", "downtime_start", "downtime_end", "reason_code", "job_affected", "resolution"],
      "naming_pattern": "DOWNTIME-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Production-Records/Downtime/{YYYY}",
      "online": true,
      "decision_score": 90
    },
    "PO-EXCEPTION": {
      "label": "PO Exception",
      "label_vi": "Ngoại lệ đơn hàng mua",
      "description": "Purchase order exception or deviation requiring supply chain approval",
      "form_code": null,
      "counter_digits": 3,
      "departments_allowed": ["SCM"],
      "variables": ["po_number", "supplier", "exception_type", "justification", "approver"],
      "naming_pattern": "PO-EXCEPTION-{YYYY}-{NNN}",
      "sharepoint_path": "HESEM-Records/Supply-Chain-Records/PO-Exception/{YYYY}",
      "online": false,
      "decision_score": null
    }
  },

