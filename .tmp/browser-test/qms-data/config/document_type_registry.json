  "validation": {
    "file_name_max_length": 120,
    "allowed_characters": "A-Za-z0-9_-.",
    "segment_separator": "_",
    "word_separator": "-",
    "date_format": "YYYYMMDD",
    "time_format": "HHMM",
    "rules": [
      {"check": "no_spaces_or_special_chars", "action": "REJECT"},
      {"check": "date_segment_present", "action": "REJECT"},
      {"check": "filled_form_has_version", "action": "REJECT"},
      {"check": "filled_form_version_matches_active", "action": "FLAG_OBSOLETE"},
      {"check": "job_evidence_has_job_number", "action": "REJECT"},
      {"check": "eng_baseline_has_version", "action": "REJECT"},
      {"check": "duplicate_filename_same_folder", "action": "REJECT"},
      {"check": "filename_exceeds_120_chars", "action": "WARN"},
      {"check": "record_type_not_in_dictionary", "action": "FLAG"},
      {"check": "date_format_invalid", "action": "REJECT"},
      {"check": "part_number_mismatch_folder", "action": "REJECT"}
    ]
  }
}