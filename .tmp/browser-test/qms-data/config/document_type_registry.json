  "naming_rules": {
    "record_id_format": {
      "pattern": "{PREFIX}-{YYYY}-{PADDED_SEQ}",
      "description": "Server-assigned unique Record-ID for formal quality records",
      "description_vi": "Mã hồ sơ do server cấp tự động, duy nhất",
      "examples": ["NCR-2026-043", "CAPA-2026-008", "FAI-2026-016"]
    },
    "form_blank_format": {
      "pattern": "FRM-{code}_{Title}_V{ver}.{ext}",
      "description": "Version-stamped form template for download",
      "description_vi": "Mẫu form có đánh dấu version để tải",
      "examples": ["FRM-302_Setup-Sheet-and-Tool-List_V3.2.xlsx", "FRM-631_NCR-Report_V2.1.xlsx"]
    },
    "form_filled_format": {
      "pattern": "FRM-{code}_V{ver}_{scope}_{YYYYMMDD}_{HHMM}-{UserID}.{ext}",
      "description": "Filled form record with scope, date, time, and user identification",
      "description_vi": "Form đã điền với phạm vi, ngày, giờ, người điền",
      "examples": ["FRM-631_V2.1_NCR-2026-043_20260327_0830-NVA.xlsx"]
    },
    "job_evidence_format": {
      "pattern": "{RecordType}_{JobNum}_{PartRev}_{YYYYMMDD}_{HHMM}-{UserID}.{ext}",
      "description": "Evidence file linked to a specific job order",
      "description_vi": "File evidence gắn với lệnh sản xuất cụ thể",
      "examples": ["CMM_JOB-2026-0042_714XXXX-REVA-OP10_20260327_0900-QC1.csv"]
    },
    "nonjob_evidence_format": {
      "pattern": "{RecordType}_{scope}_{YYYYMMDD}_{HHMM}-{UserID}.{ext}",
      "description": "Evidence file not linked to a job (training, audit, department)",
      "description_vi": "File evidence không gắn job (đào tạo, audit, phòng ban)",
      "examples": ["REPORT_AUD-2026-IA03_20260327_0900-QMS1.pdf"]
    },
    "eng_baseline_format": {
      "pattern": "{FileType}_{PartRev}_{Operation}_{MachineFamily}_V{ver}.{ext}",
      "description": "Engineering baseline file versioned by part revision",
      "description_vi": "File baseline kỹ thuật theo version part",
      "examples": ["NC_714XXXX-REVA_OP10_5AX_V3.nc"]
    },
    "asset_record_format": {
      "pattern": "{AssetType}-{AssetID}_{DocType}_{YYYYMMDD}_{HHMM}-{UserID}.{ext}",
      "description": "Tooling, fixture, or gage record per asset",
      "description_vi": "Hồ sơ tài sản (đồ gá, thiết bị đo)",
      "examples": ["GAGE-CMM-005_CAL-CERT_20260327_0800-QC1.pdf"]
    }
  },

