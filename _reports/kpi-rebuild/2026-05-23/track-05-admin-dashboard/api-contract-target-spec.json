  "admin_registry_get_response": {
    "config": {
      "registry_id": "string|null",
      "registry_version": "string|null",
      "schema_version": "int",
      "editable_fields": [
        "thresholds",
        "owner_role",
        "data_stewardship_role",
        "cadence",
        "decision_action",
        "action_reference",
        "counter_metric",
        "data_contract_gap",
        "target_graduation_condition",
        "evidence_source",
        "blocking_conditions"
      ],
      "admin_views": {
        "counts": "object",
        "official_kpis": "Metric[]",
        "operating_metrics": "Metric[]",
        "gate_control_metrics": "Metric[]",
        "role_scorecards": "RoleScorecardSummary[]",
        "health_indicators": "Metric[]",
        "counter_metrics": "CounterMetric[]",
        "staged_metrics": "Metric[]",
        "retired_metrics": "Metric[]",
        "data_contracts": "DataContractRow[]",
        "gate_coverage": "GateCoverage",
        "integrity_status": "IntegrityStatus"
      }
    }
  },
  "kpi_catalog_response": {
    "catalog": {
      "registry_version": "string|null",
      "schema_version": "int",
      "authority_rule": "string|null",
      "metric_types": [
        "kpi",
        "operating_metric",
        "gate_control_metric",
        "role_performance_measure",
        "health_indicator",
        "counter_metric"
      ],
      "metrics": [
        {
          "canonical_code": "OTD",
          "metric_type": "kpi",
          "usage_types": [
            "annex122_governance",
            "executive_scorecard",
            "runtime_calculated"
          ],
          "is_official_kpi": true,
          "calculation_status": "runtime_calculated",
          "data_contract_status": "approved_runtime",
          "scorecard_scoring_status": "active_runtime",
          "thresholds": {},
          "owner_role": "PD",
          "decision_action": "string",
          "counter_metric": {},
          "blocking_conditions": [],
          "input_endpoint": "POST /api/kpi/OTD/input",
          "runtime_endpoint": "GET /api/kpi/OTD"
        }
      ],
      "jd_scorecards": {
        "roles": "RoleCode => active_scorecard/candidate_bank/optional_rotate/do_not_use projection"
      },
      "gate_coverage": {
        "total_gate_metrics": "int",
        "with_linked_cdr": "int",
        "coverage_pct": "float",
        "missing_cdr_codes": "string[]",
        "by_gate": "GateGroup[]"
      },
      "integrity_status": {
        "status": "PASS|WARN|FAIL",
        "finding_count": "int",
        "status_counts": "object",
        "metric_type_counts": "object",
        "findings": "IntegrityFinding[]"
      }
    }
  },
  "save_policy": {
    "rbac": "AdminController requires authenticated admin_roles plus ceo/general_director-style roles",
    "csrf": "required for admin_kpi_registry_save",
    "schema_version_gate": "runtime overlay ignored when older than seed schema_version",
    "raw_json_editor": false,
    "runtime_formula_edit_from_ui": false,
    "new_metric_default_status": "staged_data_contract",
    "new_metric_required_fields": [
      "canonical_code",
      "name_vi|name",
      "thresholds.green_point",
      "thresholds.yellow_point",
      "data_contract_gap",
      "target_graduation_condition"
    ]
