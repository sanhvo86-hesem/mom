# Generated by tools/vps-setup/scripts/deploy.sh on every successful deploy.
# Frontend (00-version-check.js) polls it to trigger auto hard-reload.
mom/build-info.json
# Imported by mom/sw.js — changing its bytes is what bumps the service
# worker hash so the browser detects each deploy and runs activate().
mom/sw-build-tag.js
mom/docs/tmp/
mom/docs/forms/**/.backups/
mom/docs/forms/**/*.bak
# DocumentLocaleAutomationService writes auto-translated siblings next to
# source docs in two shapes (depending on whether revision is set):
#   _<stem>.preview_r<rev>.<locale>.html  (revision-pinned preview)
#   _<stem>.<locale>.html                  (current published translation)
# Both are runtime cache, regenerated on demand. Match by trailing locale
# code instead of the optional `.preview_rN` middle so both shapes are
# caught. Add a new locale here when the portal grows beyond vi/en.
mom/docs/**/_*.en.html
mom/docs/**/_*.en.htm
# Ad-hoc debug scratch file from tee/sed sessions on the VPS.
mom/dbg.txt
mom/docs/system/agent-reports/
mom/docs/system/*tranche*.md
mom/release/module-builder-*
mom/release/*-smoke-*.txt
mom/release/*-sample-*.json
mom/ops/local-runtime/.php-server.*
tools/php82/
prompts/
standards/prompts/
tools/prompts/

# Root-level operational/audit documents must be promoted through release lanes,
# not silently kept beside controlled source. Sanctioned templates under
# standards/templates remain trackable because this pattern is root-only.
/*.docx
/*.pptx
/*.xlsx

