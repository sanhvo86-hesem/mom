# Workspace hygiene
.DS_Store
__pycache__/
*.py[cod]

# Generated analysis/build/test artifacts
_reports/
_build/
_Deleted/
.tmp/
.tmp/browser-test/
.tmp-*.png
.tmp-*.jpg
.tmp-*.jpeg
.tmp-*.webm
.codex-playwright/
.ai/index.log
.vscode/
mom/.phpunit.cache/
mom/_reports/
mom/docs/tmp/
mom/docs/forms/**/.backups/
mom/docs/forms/**/*.bak
mom/docs/system/agent-reports/
mom/docs/system/*tranche*.md
mom/release/module-builder-*
mom/release/*-smoke-*.txt
mom/release/*-sample-*.json
mom/ops/local-runtime/.php-server.*
tools/php82/

# Root-level operational/audit documents must be promoted through release lanes,
# not silently kept beside controlled source. Sanctioned templates under
# standards/templates remain trackable because this pattern is root-only.
/*.docx
/*.pptx
/*.xlsx

# Composer
mom/vendor/
mom/composer
mom/composer.phar

# MOM runtime noise and archives
mom/data/php_error.log
mom/data/audit.log
mom/data/sessions/**
!mom/data/sessions/README.md
mom/data/log-archive/**
!mom/data/log-archive/README.md
mom/data/online-forms/schemas/_archive/**

# Environment configuration (SECURITY FIX: Never commit secrets)
.env
.env.*
!.env.example
!.env.schema
*.local.php

# Runtime data and sensitive files
mom/data/
storage/
queue/
rate-limit/
*.log
*.jsonl

