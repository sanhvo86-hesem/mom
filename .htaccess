Options -Indexes

<IfModule mod_dir.c>
  DirectoryIndex index.php index.html
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-Permitted-Cross-Domain-Policies "none"
  Header always set Permissions-Policy "accelerometer=(), autoplay=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), publickey-credentials-get=(self), usb=()"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com https://www.gstatic.com https://translate.gstatic.com; style-src 'self' 'unsafe-inline' https://translate.google.com https://translate.googleapis.com https://www.gstatic.com https://translate.gstatic.com; img-src 'self' data: blob: https://hesem.com.vn https://www.hesem.com.vn https://translate.google.com https://translate.googleapis.com https://www.gstatic.com https://translate.gstatic.com; font-src 'self' data: https://www.gstatic.com https://translate.gstatic.com; connect-src 'self' https://translate.google.com https://translate.googleapis.com https://translate-pa.googleapis.com; frame-src 'self' https://translate.google.com https://translate.googleapis.com; media-src 'self' data: blob:; manifest-src 'self'; worker-src 'self' blob:; upgrade-insecure-requests"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block direct access to hidden files/directories while preserving ACME challenges.
  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L,NC]

  # Keep internal work product and maintenance artifacts out of the public surface.
  RewriteRule ^(?:\.git|\.vscode|\.claude|tools|_build|_Deleted|_reports|__pycache__)/ - [F,L,NC]
  RewriteRule ^mom/docs/.*(?<!\.html)(?<!\.xlsx)(?<!\.xlsm)(?<!\.xls)(?<!\.csv)$ - [F,L,NC]
  RewriteRule ^mom/SECURITY_OPERATIONS\.md$ - [F,L,NC]
  RewriteRule \.(?:zip|sql|bak|old|md|py|ps1|log|sqlite|db|pem|key|dist|tmp)$ - [F,L,NC]

  # ── Legacy redirects (301 permanent — backward compat) ──
  RewriteRule ^01-QMS-Portal/(.*)$ mom/$1 [R=301,L]
  RewriteRule ^02-Tai-Lieu-He-Thong/(.*)$ mom/docs/system/$1 [R=301,L]
  RewriteRule ^03-Tai-Lieu-Van-Hanh/(.*)$ mom/docs/operations/$1 [R=301,L]
  RewriteRule ^04-Bieu-Mau/(.*)$ mom/docs/forms/$1 [R=301,L]
  RewriteRule ^10-Training-Academy/(.*)$ mom/docs/training/$1 [R=301,L]
  RewriteRule ^11-Glossary/(.*)$ mom/docs/glossary/$1 [R=301,L]
  RewriteRule ^05-Processes/?$ mom/docs/operations/sops/index.html [R=302,L,NC]
  RewriteRule ^05-Processes/index\.html$ mom/docs/operations/sops/index.html [R=302,L,NC]
  RewriteRule ^07-Forms-Records/?$ mom/docs/forms/index.html [R=302,L,NC]
  RewriteRule ^07-Forms-Records/index\.html$ mom/docs/forms/index.html [R=302,L,NC]
  RewriteRule ^08-Organization/03-Job-Descriptions/?$ mom/docs/system/organization/03-Job-Descriptions/index.html [R=302,L,NC]
  RewriteRule ^08-Organization/03-Job-Descriptions/index\.html$ mom/docs/system/organization/03-Job-Descriptions/index.html [R=302,L,NC]

  # Route controlled documents through the portal auth gate while preserving
  # the original URL path for relative links inside HTML documents.
  RewriteRule ^(archive|mom/docs/system|mom/docs/operations|mom/docs/forms|mom/docs/training)/(.*)\.(html|xlsx|xlsm|xls|csv)$ mom/api.php?action=doc_stream&path=$1/$2.$3 [QSA,L,NC]
</IfModule>
