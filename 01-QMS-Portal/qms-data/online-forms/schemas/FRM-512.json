{
  "form_code": "FRM-512",
  "title": "Downtime Log",
  "title_vi": "Nhật ký dừng máy",
  "version": "V1",
  "category": "production",
  "frequency": "per_event",
  "sop_ref": "SOP-502",
  "description": "Ghi nhận mỗi sự kiện dừng máy: thời gian, nguyên nhân, hành động khắc phục.",
  "roles_allowed": ["admin", "production_manager", "shift_leader", "cnc_operator", "maintenance_tech"],
  "fields": [
    {"id": "event_date", "type": "date", "label": "Ngày", "label_en": "Date", "required": true, "default": "today"},
    {"id": "machine_id", "type": "text", "label": "Mã máy", "label_en": "Machine ID", "required": true, "placeholder": "VD: CNC-01"},
    {"id": "shift", "type": "select", "label": "Ca", "label_en": "Shift", "required": true, "options": [
      {"value": "1", "label": "Ca 1"},
      {"value": "2", "label": "Ca 2"},
      {"value": "3", "label": "Ca 3"}
    ]},
    {"id": "start_time", "type": "time", "label": "Bắt đầu dừng", "label_en": "Start Time", "required": true},
    {"id": "end_time", "type": "time", "label": "Kết thúc dừng", "label_en": "End Time"},
    {"id": "downtime_category", "type": "select", "label": "Phân loại", "label_en": "Category", "required": true, "options": [
      {"value": "breakdown", "label": "Hỏng máy (Breakdown)"},
      {"value": "planned_pm", "label": "Bảo trì định kỳ (Planned PM)"},
      {"value": "setup", "label": "Setup/Changeover"},
      {"value": "material_wait", "label": "Chờ vật tư"},
      {"value": "quality_hold", "label": "Hold chất lượng"},
      {"value": "no_order", "label": "Không có đơn hàng"},
      {"value": "tool_change", "label": "Thay dao/tool"},
      {"value": "operator_absent", "label": "Thiếu nhân lực"},
      {"value": "power_utility", "label": "Điện/tiện ích"},
      {"value": "other", "label": "Khác"}
    ]},
    {"id": "root_cause", "type": "textarea", "label": "Nguyên nhân", "label_en": "Root Cause", "rows": 3, "required": true},
    {"id": "corrective_action", "type": "textarea", "label": "Hành động khắc phục", "label_en": "Corrective Action", "rows": 3},
    {"id": "job_affected", "type": "text", "label": "Job bị ảnh hưởng", "label_en": "Affected Job", "placeholder": "Job number(s)"},
    {"id": "parts_scrapped", "type": "number", "label": "Số chi tiết hỏng", "label_en": "Parts Scrapped", "min": 0, "default": 0},
    {"id": "reported_by", "type": "text", "label": "Người báo cáo", "label_en": "Reported By", "required": true}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "computed_fields": [
    {"id": "duration_minutes", "formula": "time_diff(start_time, end_time)", "label": "Thời gian dừng (phút)"}
  ]
}