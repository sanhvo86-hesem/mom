{
  "form_code": "FRM-521",
  "title": "Preventive Maintenance Checklist",
  "title_vi": "Phiếu kiểm tra bảo trì phòng ngừa",
  "version": "V1",
  "category": "maintenance",
  "frequency": "per_event",
  "sop_ref": "SOP-503",
  "description": "Danh sách kiểm tra bảo trì phòng ngừa định kỳ cho máy CNC và thiết bị sản xuất.",
  "roles_allowed": ["admin", "production_manager", "maintenance_tech", "maintenance_manager", "shift_leader"],
  "fields": [
    {"id": "pm_date", "type": "date", "label": "Ngày thực hiện", "label_en": "PM Date", "required": true, "default": "today"},
    {"id": "machine_id", "type": "text", "label": "Mã máy", "label_en": "Machine ID", "required": true, "placeholder": "VD: CNC-01"},
    {"id": "machine_name", "type": "text", "label": "Tên máy", "label_en": "Machine Name", "required": true},
    {"id": "machine_location", "type": "text", "label": "Vị trí máy", "label_en": "Machine Location", "placeholder": "VD: Xưởng CNC - Khu A"},
    {
      "id": "pm_type",
      "type": "select",
      "label": "Loại bảo trì",
      "label_en": "PM Type",
      "required": true,
      "options": [
        {"value": "daily", "label": "Hàng ngày (Daily)"},
        {"value": "weekly", "label": "Hàng tuần (Weekly)"},
        {"value": "monthly", "label": "Hàng tháng (Monthly)"},
        {"value": "quarterly", "label": "Hàng quý (Quarterly)"},
        {"value": "semi_annual", "label": "6 tháng (Semi-Annual)"},
        {"value": "annual", "label": "Hàng năm (Annual)"}
      ]
    },
    {"id": "operating_hours", "type": "number", "label": "Số giờ vận hành", "label_en": "Operating Hours", "min": 0, "placeholder": "Đồng hồ máy hiện tại"},
    {
      "id": "checklist_items",
      "type": "table",
      "label": "Hạng mục kiểm tra",
      "label_en": "Checklist Items",
      "min_rows": 1,
      "max_rows": 40,
      "columns": [
        {"id": "item_no", "type": "text", "label": "STT", "width": "8%", "required": true},
        {"id": "check_item", "type": "text", "label": "Hạng mục", "width": "30%", "required": true},
        {"id": "standard", "type": "text", "label": "Tiêu chuẩn", "width": "18%"},
        {"id": "result", "type": "select", "label": "Kết quả", "width": "14%", "required": true, "options": [
          {"value": "ok", "label": "Đạt (OK)", "color": "#2f9e44"},
          {"value": "ng", "label": "Không đạt (NG)", "color": "#e03131"},
          {"value": "adjusted", "label": "Đã điều chỉnh", "color": "#e67700"},
          {"value": "na", "label": "N/A", "color": "#868e96"}
        ]},
        {"id": "action_taken", "type": "text", "label": "Hành động", "width": "20%"},
        {"id": "remark", "type": "text", "label": "Ghi chú", "width": "10%"}
      ]
    },
    {
      "id": "lubrication_done",
      "type": "checkbox",
      "label": "Đã tra dầu / bôi trơn",
      "label_en": "Lubrication Done",
      "default": false
    },
    {
      "id": "coolant_level_checked",
      "type": "checkbox",
      "label": "Đã kiểm tra mức dung dịch cắt",
      "label_en": "Coolant Level Checked",
      "default": false
    },
    {
      "id": "filter_cleaned",
      "type": "checkbox",
      "label": "Đã vệ sinh bộ lọc",
      "label_en": "Filters Cleaned",
      "default": false
    },
    {
      "id": "parts_replaced",
      "type": "textarea",
      "label": "Phụ tùng đã thay thế",
      "label_en": "Parts Replaced",
      "rows": 3,
      "placeholder": "Liệt kê phụ tùng đã thay (nếu có)..."
    },
    {
      "id": "overall_condition",
      "type": "select",
      "label": "Tình trạng tổng thể máy",
      "label_en": "Overall Machine Condition",
      "required": true,
      "options": [
        {"value": "good", "label": "Tốt (Good)", "color": "#2f9e44"},
        {"value": "acceptable", "label": "Chấp nhận được (Acceptable)", "color": "#1971c2"},
        {"value": "needs_repair", "label": "Cần sửa chữa (Needs Repair)", "color": "#e67700"},
        {"value": "critical", "label": "Nghiêm trọng (Critical)", "color": "#e03131"}
      ]
    },
    {"id": "next_pm_date", "type": "date", "label": "Ngày bảo trì tiếp theo", "label_en": "Next PM Date", "required": true},
    {"id": "performed_by", "type": "text", "label": "Người thực hiện", "label_en": "Performed By", "required": true},
    {"id": "verified_by", "type": "text", "label": "Người xác nhận", "label_en": "Verified By"},
    {"id": "notes", "type": "textarea", "label": "Ghi chú", "label_en": "Notes", "rows": 3, "placeholder": "Các lưu ý hoặc đề xuất bảo trì bổ sung..."}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_critical": ["maintenance_manager", "production_manager"],
    "on_submit": ["maintenance_manager"]
  }
}
