{
  "_meta": {
    "version": "1.0",
    "created": "2026-03-28",
    "description": "Reusable field group templates for online form schema builder. Each block = pre-configured group of variables from variable_library."
  },
  "blocks": {
    "header_basic": {
      "label": "Basic Header",
      "label_vi": "Tiêu đề cơ bản",
      "description": "Date, shift, department — common to most forms",
      "variables": ["event_date", "shift_code", "department_code", "submitted_by"]
    },
    "job_context": {
      "label": "Job Context",
      "label_vi": "Ngữ cảnh đơn hàng",
      "description": "Job number, work order, part number, revision",
      "variables": ["job_number", "work_order_id", "part_number", "part_revision", "customer_id"]
    },
    "kpi_snapshot": {
      "label": "KPI Snapshot",
      "label_vi": "Chỉ số KPI",
      "description": "OTD, FPY, OEE percentages",
      "variables": ["otd_percent", "fpy_percent", "oee_percent"]
    },
    "machine_context": {
      "label": "Machine Context",
      "label_vi": "Ngữ cảnh máy",
      "description": "Machine ID, work center, operator",
      "variables": ["machine_id", "work_center_id", "operator_id", "nc_program_id"]
    },
    "defect_detail": {
      "label": "Defect Detail",
      "label_vi": "Chi tiết lỗi",
      "description": "Defect code, description, severity, disposition",
      "variables": ["defect_code", "defect_description", "severity", "qty_affected", "disposition"]
    },
    "inspection_result": {
      "label": "Inspection Result",
      "label_vi": "Kết quả kiểm tra",
      "description": "Inspector, result, sample size, pass/fail counts",
      "variables": ["inspector_id", "inspection_result", "sample_size", "qty_passed", "qty_failed"]
    },
    "material_info": {
      "label": "Material Information",
      "label_vi": "Thông tin vật liệu",
      "description": "Material spec, heat number, supplier, cert",
      "variables": ["material_spec", "heat_lot_number", "supplier_name", "cert_number"]
    },
    "approval_block": {
      "label": "Approval Block",
      "label_vi": "Khối phê duyệt",
      "description": "Prepared by, approved by, dates",
      "variables": ["prepared_by", "prepared_date", "approved_by", "approved_date", "approval_status"]
    },
    "escalation_block": {
      "label": "Escalation Block",
      "label_vi": "Khối leo thang",
      "description": "Escalation needed, note, target role",
      "variables": ["escalation_needed", "escalation_note", "escalation_target_role"]
    },
    "root_cause_block": {
      "label": "Root Cause Analysis",
      "label_vi": "Phân tích nguyên nhân gốc",
      "description": "Root cause code, description, method used",
      "variables": ["root_cause_code", "root_cause_description", "investigation_method"]
    },
    "corrective_action_block": {
      "label": "Corrective Action",
      "label_vi": "Hành động khắc phục",
      "description": "Action plan, implementation date, verification",
      "variables": ["corrective_action_plan", "implementation_date", "verification_method", "verification_result"]
    },
    "tool_context": {
      "label": "Tool Context",
      "label_vi": "Ngữ cảnh dụng cụ",
      "description": "Tool ID, tool life, fixture, gage",
      "variables": ["tool_id", "tool_life_remaining", "fixture_id", "gage_id"]
    },
    "downtime_detail": {
      "label": "Downtime Detail",
      "label_vi": "Chi tiết dừng máy",
      "description": "Downtime category, start/end, duration, impact",
      "variables": ["downtime_category", "downtime_start", "downtime_end", "downtime_minutes", "downtime_reason"]
    },
    "training_context": {
      "label": "Training Context",
      "label_vi": "Ngữ cảnh đào tạo",
      "description": "Training type, topic, instructor, duration",
      "variables": ["training_type", "training_topic", "instructor_id", "training_duration_hours"]
    },
    "shipping_detail": {
      "label": "Shipping Detail",
      "label_vi": "Chi tiết giao hàng",
      "description": "Ship method, tracking, qty shipped, packing",
      "variables": ["shipping_method", "tracking_number", "qty_shipped", "packaging_type", "ship_date"]
    },
    "calibration_detail": {
      "label": "Calibration Detail",
      "label_vi": "Chi tiết hiệu chuẩn",
      "description": "Gage ID, cal standard, result, next due",
      "variables": ["gage_id", "calibration_standard", "calibration_result", "next_calibration_date"]
    }
  }
}
