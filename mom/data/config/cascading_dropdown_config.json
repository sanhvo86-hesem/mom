      "CAPA":         { "label": "Corrective Action",            "label_vi": "Hanh dong khac phuc phong ngua",       "digits": 3, "format": "CAPA-{YYYY}-{NNN}",         "form": "FRM-641" },
      "FAI":          { "label": "First Article Inspection",     "label_vi": "Kiem tra san pham dau tien",           "digits": 3, "format": "FAI-{YYYY}-{NNN}",          "form": "FRM-311" },
      "TRN":          { "label": "Training Event",               "label_vi": "Su kien dao tao",                     "digits": 3, "format": "TRN-{YYYY}-{NNN}",          "form": "FRM-802" },
      "AUD":          { "label": "Audit",                        "label_vi": "Danh gia noi bo / ben ngoai",         "digits": 3, "format": "AUD-{YYYY}-IA{NN}",         "form": "FRM-913" },
      "ECR":          { "label": "Engineering Change Request",   "label_vi": "Yeu cau thay doi ky thuat",           "digits": 3, "format": "ECR-{YYYY}-{NNN}",          "form": "FRM-161" },
      "IMP":          { "label": "Improvement Project",          "label_vi": "Du an cai tien",                      "digits": 3, "format": "IMP-{YYYY}-{CODE}",         "form": null },
      "MR":           { "label": "Management Review",            "label_vi": "Xem xet cua lanh dao",               "digits": 2, "format": "MR-{YYYY}-Q{N}",            "form": "FRM-911" },
      "RISK":         { "label": "Risk Review",                  "label_vi": "Danh gia rui ro",                     "digits": 2, "format": "RISK-{YYYY}-R{NN}",         "form": "FRM-131" },
      "CAL":          { "label": "Calibration Record",           "label_vi": "Ho so hieu chuan",                    "digits": 3, "format": "CAL-{EquipCode}-{NNN}",     "form": "FRM-601" },
      "SCAR":         { "label": "Supplier Corrective Action",   "label_vi": "Hanh dong khac phuc nha cung cap",   "digits": 3, "format": "SCAR-{YYYY}-{NNN}",         "form": "FRM-403" },
      "DOWNTIME":     { "label": "Downtime Record",              "label_vi": "Ghi nhan dung may",                   "digits": 3, "format": "DOWNTIME-{YYYY}-{NNN}",     "form": "FRM-512" },
      "PO-EXCEPTION": { "label": "PO Exception",                 "label_vi": "Ngoai le don hang mua",              "digits": 3, "format": "PO-EXCEPTION-{YYYY}-{NNN}", "form": null }
    },
    "counter_source": "data/counters/_registry.json",
    "auto_increment": true,
    "year_reset": true
  }
}
