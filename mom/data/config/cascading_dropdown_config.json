{
  "_meta": {
    "version": "1.0",
    "created": "2026-03-29",
    "description": "Cascading dropdown configuration for Form Hub Tab 2 (Fill & Download) and Tab 3 (Record ID allocation). Each cascade defines ordered levels; UI renders one dropdown per level, filtering next level based on selection."
  },

  "fill_download": {
