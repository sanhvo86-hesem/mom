  "kpi_calculations": {
    "otd_percent": {
      "formula": "(COUNT(SO where shipped_date <= due_date) / COUNT(SO where status IN [shipped, closed])) * 100",
      "unit": "%",
      "target": 95
    },
    "on_time_job": {
      "formula": "(COUNT(JO where completed_date <= due_date) / COUNT(JO where status IN [completed, closed])) * 100",
      "unit": "%",
      "target": 90
    },
    "wo_efficiency": {
      "formula": "(run_time_est / run_time_actual) * 100",
      "unit": "%",
      "target": 85
    },
    "scrap_rate": {
      "formula": "(SUM(qty_scrap) / SUM(qty_completed + qty_scrap)) * 100",
      "unit": "%",
      "target_max": 3
    }
  }
}
