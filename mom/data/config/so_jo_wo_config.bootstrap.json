          "color": "#14b8a6"
        },
        "in_production": {
          "label": "In Production",
          "label_vi": "Đang sản xuất",
          "color": "#f59e0b"
        },
        "shipped": {
          "label": "Shipped",
          "label_vi": "Đã giao hàng",
          "color": "#10b981"
        },
        "closed": {
          "label": "Closed",
          "label_vi": "Đóng",
          "color": "#6b7280"
        },
        "cancelled": {
