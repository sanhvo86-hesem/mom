        "quoted",
        "confirmed",
        "engineering_ready",
        "in_production",
        "shipped",
        "closed",
        "cancelled"
      ],
      "transitions": {
        "draft": [
          "quoted",
          "cancelled"
        ],
        "quoted": [
          "confirmed",
          "draft",
          "cancelled"
        ],
        "confirmed": [
          "engineering_ready",
          "cancelled"
        ],
        "engineering_ready": [
          "in_production",
          "cancelled"
        ],
        "in_production": [
          "shipped",
          "cancelled"
        ],
        "shipped": [
          "closed"
        ],
        "closed": [],
        "cancelled": []
      },
      "labels": {
        "draft": {
          "label": "Draft",
          "label_vi": "Nháp",
          "color": "#9ca3af"
        },
        "quoted": {
          "label": "Quoted",
          "label_vi": "Đã báo giá",
          "color": "#3b82f6"
        },
        "confirmed": {
          "label": "Confirmed",
          "label_vi": "Đã xác nhận",
          "color": "#8b5cf6"
        },
        "engineering_ready": {
