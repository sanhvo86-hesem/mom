{
  "_meta": {
    "version": "1.1",
    "created": "2026-03-29",
    "description": "Configuration for the 3-level order hierarchy: Sales Order (SO) > Job Order (JO) > Work Order (WO). Expanded to align promise management, engineering readiness, launch governance, and modern portal role mappings."
  },
  "levels": [
    "sales_order",
    "job_order",
    "work_order"
  ],
  "hierarchy": "One SO contains one or more JOs. One JO contains one or more WOs. Each WO = one operation on one machine.",
  "sales_order": {
    "prefix": "SO",
    "format": "SO-{YYYY}-{NNNN}",
    "digits": 4,
    "year_reset": true,
    "description": "Customer purchase order converted to internal sales order. Top-level container for all production work.",
    "fields": [
      {
        "key": "so_number",
        "type": "string",
        "required": true,
        "label": "SO Number"
      },
      {
        "key": "customer_id",
        "type": "string",
        "required": true,
        "label": "Customer ID"
      },
      {
        "key": "customer_name",
        "type": "string",
        "required": true,
        "label": "Customer Name"
      },
      {
        "key": "customer_po",
        "type": "string",
        "required": true,
        "label": "Customer PO Number"
      },
      {
        "key": "order_date",
        "type": "date",
        "required": true,
        "label": "Order Date"
      },
      {
        "key": "due_date",
        "type": "date",
        "required": true,
        "label": "Due Date"
      },
      {
        "key": "total_qty",
        "type": "integer",
        "required": true,
        "label": "Total Quantity"
      },
      {
        "key": "total_value",
        "type": "number",
        "required": false,
        "label": "Order Value (USD)"
      },
      {
        "key": "priority",
        "type": "string",
        "required": false,
        "label": "Priority",
        "enum": [
          "normal",
          "high",
          "urgent",
          "aog"
        ]
      },
      {
        "key": "contract_review",
        "type": "string",
        "required": false,
        "label": "Contract Review Ref"
      },
      {
        "key": "special_requirements",
        "type": "text",
        "required": false,
        "label": "Special Requirements / Notes"
      },
      {
        "key": "status",
        "type": "string",
        "required": true,
        "label": "Status"
      }
    ],
    "roles_view": [
      "ceo",
      "production_director",
      "sales_manager",
      "estimator",
      "customer_service",
      "quality_manager",
      "planning_manager",
      "production_planner",
      "cnc_workshop_manager",
      "engineering_manager",
      "supply_chain_manager",
      "admin"
    ],
    "roles_edit": [
      "sales_manager",
      "estimator",
      "customer_service",
      "supply_chain_manager"
    ],
    "roles_create": [
      "sales_manager",
      "estimator",
      "customer_service"
    ],
    "roles_delete": [
      "sales_manager"
    ]
  },
