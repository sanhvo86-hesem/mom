{
  "moduleId": "M2-orders",
  "title": { "vi": "Đơn hàng", "en": "Orders" },
  "subtitle": { "vi": "Quản lý SO → JO → WO, hợp đồng, giao hàng", "en": "Manage SO → JO → WO, contracts, shipping" },
  "icon": "📦",
  "route": "/orders",
  "roles": ["ceo", "sales_manager", "estimator", "qa_manager", "production_director", "planner", "it_admin"],
  "version": 1,
  "createdBy": "system",
  "createdAt": "2026-04-02T00:00:00+07:00",
  "updatedAt": "2026-04-02T00:00:00+07:00",
  "tabs": [
    {
      "tabId": "overview",
      "title": { "vi": "Tổng quan", "en": "Overview" },
      "icon": "📊",
      "blocks": [
        {
          "blockId": "blk-kpi-orders",
          "type": "kpi-row",
          "visible": true,
          "order": 1,
          "title": { "vi": "Chỉ số đơn hàng", "en": "Order KPIs" },
          "config": {
            "items": [
              { "label": { "vi": "SO hoạt động", "en": "Active SOs" }, "dataSource": { "api": "order_dashboard_kpi", "method": "GET", "field": "active_so_count" }, "color": "var(--brand-2)", "format": "number" },
              { "label": { "vi": "OTD %", "en": "OTD %" }, "dataSource": { "api": "order_dashboard_kpi", "method": "GET", "field": "on_time_pct" }, "color": "var(--green)", "suffix": "%", "format": "number" },
              { "label": { "vi": "Quá hạn", "en": "Overdue" }, "dataSource": { "api": "order_dashboard_kpi", "method": "GET", "field": "overdue_count" }, "color": "var(--red)", "format": "number" },
              { "label": { "vi": "Đang hold", "en": "On Hold" }, "dataSource": { "api": "order_dashboard_kpi", "method": "GET", "field": "active_holds" }, "color": "var(--amber)", "format": "number" },
              { "label": { "vi": "Hoàn thành", "en": "Completed" }, "dataSource": { "api": "order_dashboard_kpi", "method": "GET", "field": "completed_total" }, "color": "var(--green)", "format": "number" }
            ]
          }
        },
        {
          "blockId": "blk-filter-so",
          "type": "filter-bar",
          "visible": true,
          "order": 2,
          "config": {
            "filters": [
              { "key": "search", "type": "search", "placeholder": { "vi": "Tìm SO, khách hàng, PO...", "en": "Search SO, customer, PO..." } },
              { "key": "status", "type": "select", "allLabel": { "vi": "Tất cả trạng thái", "en": "All statuses" }, "options": [
                { "value": "draft", "label": "Draft" },
                { "value": "confirmed", "label": "Confirmed" },
                { "value": "in_production", "label": "In Production" },
                { "value": "shipped", "label": "Shipped" },
                { "value": "closed", "label": "Closed" }
              ]},
              { "key": "date_from", "type": "date" },
              { "key": "date_to", "type": "date" }
            ],
            "showRefresh": true
          }
        },
        {
          "blockId": "blk-table-so",
          "type": "data-table",
          "visible": true,
          "order": 3,
          "title": { "vi": "Danh sách đơn hàng", "en": "Sales Orders" },
          "config": {
            "dataSource": { "api": "order_so_list", "method": "GET", "dataKey": "sales_orders" },
            "columns": [
              { "key": "so_number", "label": { "vi": "Số SO", "en": "SO#" }, "sortable": true, "filterable": true, "width": "130px", "pinned": "left" },
              { "key": "customer_name", "label": { "vi": "Khách hàng", "en": "Customer" }, "sortable": true, "filterable": true },
              { "key": "customer_po", "label": { "vi": "PO khách", "en": "Customer PO" }, "sortable": true },
              { "key": "order_date", "label": { "vi": "Ngày đặt", "en": "Order Date" }, "type": "date", "sortable": true },
              { "key": "due_date", "label": { "vi": "Hạn giao", "en": "Due Date" }, "type": "date", "sortable": true, "conditionalFormat": [
                { "condition": "{{ new Date(value) < new Date() && row.status !== 'shipped' && row.status !== 'closed' }}", "style": { "color": "var(--red)", "fontWeight": "700" } }
              ]},
              { "key": "total_qty", "label": { "vi": "SL", "en": "Qty" }, "type": "number", "align": "right", "sortable": true },
              { "key": "priority", "label": { "vi": "Ưu tiên", "en": "Priority" }, "type": "badge", "sortable": true },
              { "key": "status", "label": { "vi": "Trạng thái", "en": "Status" }, "type": "badge", "sortable": true, "filterable": true }
            ],
            "pagination": true,
            "pageSize": 25,
            "features": {
              "columnResize": true,
              "multiSort": true,
              "columnFilter": true,
              "globalSearch": true,
              "rowSelection": false,
              "export": ["csv"]
            },
            "rowClick": { "action": "navigate-tab", "tab": "detail", "passField": "so_number" },
            "emptyMessage": { "vi": "Chưa có đơn hàng nào", "en": "No orders yet" },
            "emptyIcon": "📦"
          }
        },
        {
          "blockId": "blk-toolbar-create",
          "type": "action-toolbar",
          "visible": true,
          "order": 4,
          "config": {
            "buttons": [
              { "label": { "vi": "+ Tạo SO", "en": "+ Create SO" }, "action": "navigate-tab", "tab": "create-so", "variant": "primary", "icon": "➕" },
              { "label": { "vi": "Xem cây đơn", "en": "View Hierarchy" }, "action": "navigate-tab", "tab": "hierarchy", "variant": "secondary", "icon": "🌳" }
            ]
          }
        }
      ]
    },
    {
      "tabId": "create-so",
      "title": { "vi": "Tạo SO", "en": "Create SO" },
      "icon": "➕",
      "blocks": [
        {
          "blockId": "blk-form-so",
          "type": "form-standard",
          "visible": true,
          "order": 1,
          "title": { "vi": "Tạo đơn hàng mới", "en": "Create New Sales Order" },
          "config": {
            "columns": 2,
            "submitApi": { "action": "order_so_create", "method": "POST" },
            "onSuccess": { "type": "chain", "actions": [
              { "type": "toast", "message": "{{ _t('Tạo SO thành công!', 'SO created!') }}", "toastType": "success" },
              { "type": "navigate", "tab": "overview" },
              { "type": "refresh", "blocks": ["blk-table-so", "blk-kpi-orders"] }
            ]},
            "fields": [
              { "key": "customer_id", "label": { "vi": "Khách hàng", "en": "Customer" }, "type": "text", "validation": { "required": true }, "placeholder": { "vi": "Mã khách hàng", "en": "Customer ID" } },
              { "key": "customer_name", "label": { "vi": "Tên khách hàng", "en": "Customer Name" }, "type": "text", "validation": { "required": true } },
              { "key": "customer_po", "label": { "vi": "PO khách hàng", "en": "Customer PO" }, "type": "text", "validation": { "required": true } },
              { "key": "order_date", "label": { "vi": "Ngày đặt hàng", "en": "Order Date" }, "type": "date", "defaultValue": "{{new Date().toISOString().substring(0,10)}}", "validation": { "required": true } },
              { "key": "due_date", "label": { "vi": "Ngày giao hàng", "en": "Due Date" }, "type": "date", "validation": { "required": true } },
              { "key": "requested_date", "label": { "vi": "Ngày KH cần", "en": "Requested Date" }, "type": "date" },
              { "key": "total_qty", "label": { "vi": "Tổng số lượng", "en": "Total Quantity" }, "type": "number", "validation": { "required": true, "min": 1 } },
              { "key": "total_value", "label": { "vi": "Giá trị (USD)", "en": "Value (USD)" }, "type": "number" },
              { "key": "priority", "label": { "vi": "Mức ưu tiên", "en": "Priority" }, "type": "select", "options": [
                { "value": "normal", "label": "Normal" },
                { "value": "high", "label": "High" },
                { "value": "urgent", "label": "Urgent" },
                { "value": "aog", "label": "AOG" }
              ], "defaultValue": "normal" },
              { "key": "incoterm_code", "label": { "vi": "Incoterm", "en": "Incoterm" }, "type": "select", "options": [
                { "value": "EXW", "label": "EXW" },
                { "value": "FCA", "label": "FCA" },
                { "value": "FOB", "label": "FOB" },
                { "value": "CIF", "label": "CIF" },
                { "value": "DDP", "label": "DDP" }
              ]},
              { "key": "special_requirements", "label": { "vi": "Yêu cầu đặc biệt", "en": "Special Requirements" }, "type": "textarea", "span": "full" }
            ],
            "cancelAction": { "type": "navigate", "tab": "overview" }
          }
        }
      ]
    },
    {
      "tabId": "hierarchy",
      "title": { "vi": "Cây đơn hàng", "en": "Hierarchy" },
      "icon": "🌳",
      "blocks": [
        {
          "blockId": "blk-tree-hierarchy",
          "type": "data-tree",
          "visible": true,
          "order": 1,
          "title": { "vi": "SO → JO → WO", "en": "SO → JO → WO" },
          "config": {
            "dataSource": { "api": "order_hierarchy", "method": "GET", "dataKey": "hierarchy" },
            "childrenKey": "job_orders",
            "expandLevel": 2,
            "nodeTemplate": "{{ node.so_number || node.jo_number || node.wo_number }} — {{ node.status }}"
          }
        }
      ]
    },
    {
      "tabId": "contract-review",
      "title": { "vi": "Xem xét HĐ", "en": "Contract Review" },
      "icon": "📝",
      "blocks": [
        {
          "blockId": "blk-info-cr",
          "type": "info-banner",
          "visible": true,
          "order": 1,
          "config": {
            "text": { "vi": "12 hạng mục xem xét hợp đồng theo AS9100D 8.2.3", "en": "12 contract review items per AS9100D 8.2.3" },
            "type": "info",
            "dismissable": false
          }
        },
        {
          "blockId": "blk-cr-progress",
          "type": "kpi-row",
          "visible": true,
          "order": 2,
          "config": {
            "items": [
              { "label": { "vi": "Tiến độ review", "en": "Review Progress" }, "dataSource": { "api": "order_contract_review", "method": "GET", "field": "completion_pct" }, "color": "var(--brand-2)", "suffix": "%" }
            ]
          }
        }
      ]
    },
    {
      "tabId": "shipping",
      "title": { "vi": "Giao hàng", "en": "Shipping" },
      "icon": "🚚",
      "blocks": [
        {
          "blockId": "blk-shipment-gate",
          "type": "data-table",
          "visible": true,
          "order": 1,
          "title": { "vi": "Shipment Readiness Gate", "en": "Shipment Readiness Gate" },
          "config": {
            "dataSource": { "api": "order_shipment_gate", "method": "GET", "dataKey": "shipment_gate.items" },
            "columns": [
              { "key": "code", "label": { "vi": "Mã", "en": "Code" }, "width": "80px" },
              { "key": "label", "label": { "vi": "Hạng mục", "en": "Item" } },
              { "key": "status", "label": { "vi": "Kết quả", "en": "Result" }, "type": "badge", "conditionalFormat": [
                { "condition": "{{ value === 'pass' }}", "style": { "background": "var(--green-bg)", "color": "var(--green)" } },
                { "condition": "{{ value === 'fail' }}", "style": { "background": "var(--red-bg)", "color": "var(--red)" } }
              ]}
            ],
            "pagination": false,
            "features": { "columnResize": false, "export": [] }
          }
        },
        {
          "blockId": "blk-packing",
          "type": "data-table",
          "visible": true,
          "order": 2,
          "title": { "vi": "Packing List", "en": "Packing Lists" },
          "config": {
            "dataSource": { "api": "packing_list", "method": "GET", "dataKey": "packing_lists" },
            "columns": [
              { "key": "packing_number", "label": { "vi": "Số PK", "en": "PK#" }, "sortable": true },
              { "key": "so_number", "label": { "vi": "SO", "en": "SO" } },
              { "key": "status", "label": { "vi": "Trạng thái", "en": "Status" }, "type": "badge" },
              { "key": "tracking_number", "label": { "vi": "Tracking", "en": "Tracking" } },
              { "key": "packing_date", "label": { "vi": "Ngày đóng gói", "en": "Packed Date" }, "type": "date" }
            ],
            "pagination": true,
            "pageSize": 10
          }
        },
        {
          "blockId": "blk-toolbar-packing",
          "type": "action-toolbar",
          "visible": true,
          "order": 3,
          "config": {
            "buttons": [
              { "label": { "vi": "+ Tạo Packing List", "en": "+ Create Packing List" }, "variant": "primary", "icon": "📦",
                "events": { "onClick": { "type": "openModal", "modalConfig": {
                  "title": { "vi": "Tạo Packing List", "en": "Create Packing List" },
                  "fields": [
                    { "key": "so_number", "label": { "vi": "Số SO", "en": "SO Number" }, "type": "text", "validation": { "required": true } },
                    { "key": "packing_date", "label": { "vi": "Ngày đóng gói", "en": "Packing Date" }, "type": "date" }
                  ],
                  "submitApi": { "action": "packing_create", "method": "POST" },
                  "onSuccess": { "type": "chain", "actions": [
                    { "type": "toast", "message": "Đã tạo packing list" },
                    { "type": "refresh", "blocks": ["blk-packing"] }
                  ]}
                }}}
              }
            ]
          }
        }
      ]
    },
    {
      "tabId": "detail",
      "title": { "vi": "Chi tiết", "en": "Detail" },
      "icon": "🔍",
      "blocks": [
        {
          "blockId": "blk-detail-so",
          "type": "data-detail",
          "visible": true,
          "order": 1,
          "config": {
            "dataSource": { "api": "order_so_detail", "method": "GET", "dataKey": "sales_order", "params": { "so_number": "{{ state.selectedId }}" } },
            "layout": "grid",
            "fields": [
              { "key": "so_number", "label": { "vi": "Số SO", "en": "SO Number" } },
              { "key": "customer_name", "label": { "vi": "Khách hàng", "en": "Customer" } },
              { "key": "customer_po", "label": { "vi": "PO khách", "en": "Customer PO" } },
              { "key": "status", "label": { "vi": "Trạng thái", "en": "Status" }, "type": "badge" },
              { "key": "order_date", "label": { "vi": "Ngày đặt", "en": "Order Date" }, "type": "date" },
              { "key": "due_date", "label": { "vi": "Hạn giao", "en": "Due Date" }, "type": "date" },
              { "key": "total_qty", "label": { "vi": "Số lượng", "en": "Quantity" }, "type": "number" },
              { "key": "total_value", "label": { "vi": "Giá trị", "en": "Value" }, "type": "number" },
              { "key": "priority", "label": { "vi": "Ưu tiên", "en": "Priority" }, "type": "badge" },
              { "key": "created_by", "label": { "vi": "Người tạo", "en": "Created by" } },
              { "key": "created_at", "label": { "vi": "Ngày tạo", "en": "Created" }, "type": "date" }
            ]
          }
        },
        {
          "blockId": "blk-status-flow",
          "type": "action-status-flow",
          "visible": true,
          "order": 2,
          "config": {
            "statusField": "status",
            "transitions": {
              "draft": ["confirmed", "cancelled"],
              "confirmed": ["in_production", "cancelled"],
              "in_production": ["shipped", "cancelled"],
              "shipped": ["closed"]
            },
            "transitionApi": { "action": "order_transition", "method": "POST", "bodyTemplate": { "order_type": "so", "order_id": "{{ state.selectedId }}", "target_status": "{{ targetStatus }}" } },
            "onSuccess": { "type": "chain", "actions": [
              { "type": "toast", "message": "Đã chuyển trạng thái" },
              { "type": "refresh", "blocks": ["blk-detail-so", "blk-kpi-orders"] }
            ]}
          }
        },
        {
          "blockId": "blk-notes",
          "type": "data-timeline",
          "visible": true,
          "order": 3,
          "title": { "vi": "Ghi chú & Lịch sử", "en": "Notes & History" },
          "config": {
            "dataSource": { "api": "order_timeline", "method": "GET", "dataKey": "timeline", "params": { "so_number": "{{ state.selectedId }}" } },
            "dateKey": "event_date",
            "titleKey": "event_label",
            "descKey": "details",
            "colorKey": "event_type"
          }
        }
      ]
    }
  ]
}
