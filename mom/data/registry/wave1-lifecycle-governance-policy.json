{
  "_meta": {
    "version": "1.0",
    "generatedAt": "2026-04-15T08:07:23.647Z",
    "description": "Wave 1 lifecycle normalization policy for backend-first operational control."
  },
  "objective": {
    "wave": 1,
    "name": "Lifecycle Hardening And Schema Truth",
    "statement": "Every core operational object must run either as guarded-transition runtime with explicit gates or as a persisted workflow with a verified engine bridge. Objects that still lack a real state field must be declared as schema blockers instead of being forced through generic status behavior.",
    "operating_mode": "backend_first_runtime_governance"
  },
  "lifecycle_modes": {
    "stateless": {
      "allowed_for": [
        "projections",
        "analytics_views",
        "pure_reference_sets_without_operational_gate"
      ],
      "transition_endpoint": false
    },
    "generic_status_only": {
      "allowed_for": [
        "temporary_support_records_only"
      ],
      "transition_endpoint": true,
      "deprecation_intent": "must not remain on core value-stream entities"
    },
    "guarded_transition_runtime": {
      "allowed_for": [
        "reference_master_with_operational_gate",
        "lifecycle_owner_with_db_state_field",
        "ledger_document_with_backend_guarded_release"
      ],
      "transition_endpoint": true,
      "runtime_rule": "generic transition endpoint allowed, but only through explicit registry states, guards, and allowed transition map"
    },
    "persisted": {
      "allowed_for": [
        "workflow_engine_backed_cases",
        "multi-actor_signoff_flows",
        "engine_orchestrated_processes"
      ],
      "transition_endpoint": true,
      "runtime_rule": "requires verified workflow-engine bridge before production runtime transition"
    }
  },
  "acceptance_criteria": {
    "required_for_guarded_transition_runtime": [
      "explicit_state_field_or_approved_state_field_override",
      "explicit_status_set",
      "explicit_transition_graph",
      "role_guarded_release_or_close_states",
      "audit_timestamps_and_row_version",
      "archive_not_hard_delete"
    ],
    "required_for_live_db_surface": [
      "explicit_db_operator_role_boundary_separate_from_schema_governance_roles",
      "no_legacy_role_alias_expansion_without_review",
      "csrf_required_for_mutation_and_preview_entrypoints",
      "audit_log_for_live_db_mutation"
    ],
    "required_for_schema_blocker": [
      "canonical_resource_mapping",
      "missing_state_field_explained",
      "required_db_column_defined",
      "upgrade_wave_assigned",
      "frontend_exposure_blocked_until_fixed"
    ]
  },
  "rejection_criteria": [
    "core_entity_left_on_generic_status_only_without_exception",
    "core_entity_missing_state_field_but_exposed_as_lifecycle",
    "workflow_with_explicit_transitions_but_no_runtime_mode",
    "state_field_override_without_real_db_column",
    "lifecycle_contract_without_kpi_gate_audit_linkage",
    "live_db_surface_reusing_broad_control_plane_roles_or_legacy_aliases",
    "unused_candidate_reintroduced_without_business_owner"
  ]
}
