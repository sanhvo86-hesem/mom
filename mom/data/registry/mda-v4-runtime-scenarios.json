      "scenario_id": "V4-SIM-058-001",
      "title": "StartJob missing machine evidence blocks before track-in",
      "tags": ["P58", "P0", "readiness", "mes", "real_gateway"],
      "p0_blockers": ["P0-RESOURCE-READINESS-NOT-WIRED", "P0-SCENARIO-MOCK-ONLY-FINAL-ACCEPTANCE"],
      "fixture": {
        "readiness_missing_keys": ["machine_pm"],
        "tooling_blocked": false
      },
      "command_envelope": {
        "command_name": "StartJobCommand",
        "idempotency_key": "p58-startjob-missing-machine",
        "actor_id": "operator-1",
        "actor_roles": ["production_operator"],
        "actor_permissions": ["production.job.start"],
        "reauth_at": "AUTO_NOW",
        "payload": {
          "work_order_ref": "WO-P58-001",
          "job_number": "WO-P58-001",
          "operation_seq": "10",
          "equipment_id": "MILL-P58",
          "tool_id": "TOOL-P58",
          "item_id": "ITEM-P58"
        }
      },
      "expected_acceptance": false,
      "expected_problem_code": "resource_readiness_blocked",
      "must_write_sql_contains": ["INSERT INTO resource_readiness_snapshot", "INSERT INTO audit_events"],
      "must_not_write_sql_contains": ["INSERT INTO mes_job_execution"],
      "must_emit_audit": true,
      "must_emit_outbox": false
    },
