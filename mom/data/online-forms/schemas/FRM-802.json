{
  "form_code": "FRM-802",
  "record_type": "TRN",
  "title": "Training Record",
  "title_vi": "H\u1ed3 s\u01a1 \u0111\u00e0o t\u1ea1o",
  "title_note_vi": "Kh\u00f3a m\u1ee5c ti\u00eau \u0111\u00e0o t\u1ea1o, danh s\u00e1ch tham d\u1ef1, k\u1ebft qu\u1ea3 \u0111\u00e1nh gi\u00e1 v\u00e0 d\u1ea5u v\u1ebft hi\u1ec7u l\u1ef1c n\u0103ng l\u1ef1c trong m\u1ed9t controlled record.",
  "title_note_en": "Lock training intent, attendance, assessment results, and effectiveness evidence in one controlled record.",
  "version": "V2",
  "category": "hr",
  "frequency": "per_event",
  "sop_ref": "SOP-801",
  "description_vi": "Bi\u1ec3u m\u1eabu d\u00f9ng \u0111\u1ec3 ghi nh\u1eadn \u0111\u1ea7y \u0111\u1ee7 b\u1ed1i c\u1ea3nh \u0111\u00e0o t\u1ea1o, danh s\u00e1ch nh\u00e2n s\u1ef1 tham gia, k\u1ebft qu\u1ea3 \u0111\u00e1nh gi\u00e1, b\u1eb1ng ch\u1ee9ng \u0111\u00ednh k\u00e8m v\u00e0 ph\u00ea duy\u1ec7t ph\u00e1t h\u00e0nh.",
  "description_en": "Capture training context, participant evidence, assessment results, effectiveness follow-up, and controlled release approval in one governed form.",
  "roles_allowed": [
    "admin",
    "hr_manager",
    "qa_manager",
    "production_director",
    "engineering_lead",
    "shift_leader"
  ],
  "evidence_review": {
    "approval_mode": "serial",
    "label_vi": "Ph\u00ea duy\u1ec7t tu\u1ea7n t\u1ef1",
    "label_en": "Serial approval",
    "roles_allowed": [
      "hr_manager",
      "qa_manager",
      "production_director",
      "engineering_lead",
      "shift_leader"
    ]
  },
  "signature_blocks": [
    {
      "id": "trainer_signoff",
      "label_vi": "X\u00e1c nh\u1eadn gi\u1ea3ng vi\u00ean",
      "label_en": "Trainer sign-off",
      "help_vi": "Gi\u1ea3ng vi\u00ean x\u00e1c nh\u1eadn n\u1ed9i dung \u0111\u00e3 \u0111\u01b0\u1ee3c tri\u1ec3n khai \u0111\u00fang ph\u1ea1m vi.",
      "help_en": "Trainer confirms the session content was delivered as planned."
    },
    {
      "id": "owner_release",
      "label_vi": "Ph\u00e1t h\u00e0nh h\u1ed3 s\u01a1",
      "label_en": "Owner release",
      "help_vi": "Ch\u1ee7 s\u1edf h\u1eefu h\u1ed3 s\u01a1 ch\u1ed1t hi\u1ec7u l\u1ef1c b\u1eb1ng ch\u1ee9ng \u0111\u00e0o t\u1ea1o.",
      "help_en": "Record owner releases the training evidence into the controlled record set."
    }
  ],
  "approval_flow": [
    {
      "id": "trainer_signoff",
      "required_on_submit": true
    },
    {
      "id": "owner_release",
      "required_on_submit": true
