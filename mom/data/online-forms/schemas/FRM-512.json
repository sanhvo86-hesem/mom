{
  "form_code": "FRM-512",
  "title": "Downtime Log",
  "title_vi": "Nhật ký dừng máy",
  "version": "V2",
  "category": "production",
  "frequency": "per_event",
  "delivery_mode": "online",
  "online": true,
  "decision_score": 90,
  "sop_ref": "SOP-502",
  "description": "Governed runtime for machine downtime capture with linked machine, WO, operator, tooling, root-cause categories, and recovery approval.",
  "description_vi": "Biểu mẫu runtime để ghi nhận dừng máy với máy, WO, người vận hành, tooling, nhóm nguyên nhân gốc và bước xác nhận khôi phục được kéo trực tiếp từ dữ liệu đã quản lý.",
  "roles_allowed": [
    "admin",
    "production_manager",
    "shift_leader",
    "cnc_operator",
    "maintenance_tech",
    "maintenance_manager"
  ],
  "record_context": {
    "required": ["machine_id"],
    "autofill_priority": ["wo_number", "machine_id", "work_center_id"]
  },
  "offline_package": {
    "enabled": false,
    "fallback_form": "FRM-512"
  },
  "sections": [
    {
      "id": "context",
      "title": "Runtime Context",
      "title_vi": "Ngữ cảnh runtime",
      "description": "Select the governed machine, work center, work order, and the affected tooling before recording the downtime event.",
      "description_vi": "Chọn máy, work center, work order và tooling liên quan đã được quản lý trước khi ghi nhận sự kiện dừng máy.",
      "field_ids": ["event_date", "shift", "work_center_id", "machine_id", "wo_number", "operator_id", "affected_tool_id"]
    },
    {
      "id": "event",
      "title": "Downtime Event",
      "title_vi": "Sự kiện dừng máy",
      "description": "Capture when the downtime started, how severe it is, and which 6M categories are involved.",
      "description_vi": "Ghi nhận thời điểm dừng máy, mức độ ảnh hưởng và các nhóm nguyên nhân 6M liên quan.",
      "field_ids": ["start_time", "end_time", "downtime_category", "severity", "root_cause_categories", "reason"]
    },
    {
      "id": "recovery",
      "title": "Containment & Recovery",
      "title_vi": "Ngăn chặn và khôi phục",
      "description": "Record the immediate action, scrap impact, and recovery evidence before closing the event.",
      "description_vi": "Ghi nhận hành động tức thời, lượng scrap ảnh hưởng và bằng chứng khôi phục trước khi đóng sự kiện.",
      "field_ids": ["corrective_action", "parts_scrapped", "reported_by_operator", "recovery_note"]
    }
  ],
  "fields": [
    {
      "id": "event_date",
      "type": "date",
      "label": "Event Date",
      "label_vi": "Ngày sự kiện",
      "required": true,
      "default": "today",
      "width": "third"
    },
    {
      "id": "shift",
      "type": "select",
      "label": "Shift",
      "label_vi": "Ca làm việc",
      "required": true,
      "width": "third",
      "options_source": "registry:shift_code",
      "options": [
        { "value": "1", "label": "Shift 1", "label_vi": "Ca 1" },
        { "value": "2", "label": "Shift 2", "label_vi": "Ca 2" },
        { "value": "3", "label": "Shift 3", "label_vi": "Ca 3" },
        { "value": "day", "label": "Day", "label_vi": "Hành chính" }
      ]
    },
    {
      "id": "work_center_id",
      "type": "lookup",
      "label": "Work Center",
      "label_vi": "Work center",
      "required": true,
      "width": "third",
      "lookup_source": "work_centers",
      "strict_select": true,
      "display_fields": ["work_center_id", "work_center_name"],
      "placeholder": "Search work center",
      "placeholder_vi": "Tìm work center"
    },
    {
      "id": "machine_id",
      "type": "lookup",
      "label": "Machine",
      "label_vi": "Máy",
      "required": true,
      "width": "third",
      "lookup_source": "machines",
      "strict_select": true,
      "depends_on": ["work_center_id"],
      "display_fields": ["machine_id", "machine_name", "machine_type"],
      "autofill_map": {
        "work_center_id": "work_center_id"
      },
      "placeholder": "Search machine",
      "placeholder_vi": "Tìm máy"
    },
    {
      "id": "wo_number",
      "type": "lookup",
      "label": "Work Order",
      "label_vi": "Work Order",
      "required": false,
      "width": "third",
      "lookup_source": "work_orders",
      "strict_select": true,
      "depends_on": ["machine_id"],
      "display_fields": ["wo_number", "operation_desc", "part_number", "part_revision"],
      "autofill_map": {
        "customer_id": "customer_id",
        "so_number": "so_number",
        "jo_number": "jo_number",
        "wo_number": "wo_number",
        "part_number": "part_number",
        "part_revision": "part_revision",
        "machine_id": "machine_id",
        "work_center_id": "work_center_id",
        "operator_id": "operator_id"
      },
      "placeholder": "Search affected WO",
      "placeholder_vi": "Tìm WO bị ảnh hưởng"
    },
    {
      "id": "operator_id",
      "type": "lookup",
      "label": "Machine Operator",
      "label_vi": "Người vận hành máy",
      "required": false,
      "width": "third",
      "lookup_source": "operators",
      "strict_select": true,
      "depends_on": ["work_center_id"],
      "display_fields": ["operator_id", "operator_name", "role"],
      "placeholder": "Search operator",
      "placeholder_vi": "Tìm người vận hành"
    },
    {
      "id": "affected_tool_id",
      "type": "lookup",
      "label": "Affected Tool / Fixture",
      "label_vi": "Tool / đồ gá liên quan",
      "required": false,
      "width": "third",
      "lookup_source": "tooling_assets",
      "strict_select": true,
      "depends_on": ["machine_id", "work_center_id"],
      "display_fields": ["tool_id", "tool_name", "tool_type"],
      "placeholder": "Search affected tooling",
      "placeholder_vi": "Tìm tooling liên quan"
    },
    {
      "id": "start_time",
      "type": "time",
      "label": "Downtime Start",
      "label_vi": "Bắt đầu dừng",
      "required": true,
      "width": "third"
    },
    {
      "id": "end_time",
      "type": "time",
      "label": "Downtime End",
      "label_vi": "Kết thúc dừng",
      "required": false,
      "width": "third"
    },
    {
      "id": "downtime_category",
      "type": "select",
      "label": "Category",
      "label_vi": "Phân loại dừng máy",
      "required": true,
      "width": "third",
      "options_source": "registry:downtime_category",
      "options": [
        { "value": "breakdown", "label": "Breakdown", "label_vi": "Hỏng máy" },
        { "value": "planned_pm", "label": "Planned PM", "label_vi": "Bảo trì định kỳ" },
        { "value": "setup", "label": "Setup / Changeover", "label_vi": "Setup / Changeover" },
        { "value": "material_wait", "label": "Material Wait", "label_vi": "Chờ vật tư" },
        { "value": "quality_hold", "label": "Quality Hold", "label_vi": "Hold chất lượng" },
        { "value": "tool_change", "label": "Tool Change", "label_vi": "Thay dao / tool" },
        { "value": "utility", "label": "Utility / Power", "label_vi": "Điện / tiện ích" },
        { "value": "other", "label": "Other", "label_vi": "Khác" }
      ]
    },
    {
      "id": "severity",
      "type": "select",
      "label": "Severity",
      "label_vi": "Mức độ ảnh hưởng",
      "required": true,
      "width": "third",
      "options_source": "registry:severity",
      "options": [
        { "value": "minor", "label": "Minor", "label_vi": "Nhẹ" },
        { "value": "major", "label": "Major", "label_vi": "Lớn" },
        { "value": "critical", "label": "Critical", "label_vi": "Nghiêm trọng" }
      ]
    },
    {
      "id": "root_cause_categories",
      "type": "multi_select",
      "label": "Root Cause Categories",
      "label_vi": "Nhóm nguyên nhân 6M",
      "required": true,
      "options_source": "registry:root_cause_6m",
      "options": [
        { "value": "man", "label": "Man", "label_vi": "Con người" },
        { "value": "machine", "label": "Machine", "label_vi": "Máy móc" },
        { "value": "method", "label": "Method", "label_vi": "Phương pháp" },
        { "value": "material", "label": "Material", "label_vi": "Vật liệu" },
        { "value": "measurement", "label": "Measurement", "label_vi": "Đo lường" },
        { "value": "environment", "label": "Environment", "label_vi": "Môi trường" }
      ]
    },
    {
      "id": "reason",
      "type": "textarea",
      "label": "Reason / Symptom",
      "label_vi": "Lý do / triệu chứng",
      "required": true,
      "rows": 4,
      "width": "full",
      "placeholder": "Describe what happened on the machine",
      "placeholder_vi": "Mô tả điều gì đang xảy ra trên máy"
    },
    {
      "id": "corrective_action",
      "type": "textarea",
      "label": "Corrective Action",
      "label_vi": "Hành động khắc phục",
      "required": false,
      "rows": 4,
      "width": "full",
      "placeholder": "Containment and corrective action",
      "placeholder_vi": "Mô tả hành động ngăn chặn và khắc phục"
    },
    {
      "id": "parts_scrapped",
      "type": "number",
      "label": "Parts Scrapped",
      "label_vi": "Số lượng scrap",
      "required": false,
      "min": 0,
      "default": 0,
      "width": "third"
    },
    {
      "id": "reported_by_operator",
      "type": "lookup",
      "label": "Reported By",
      "label_vi": "Người báo cáo",
      "required": true,
      "width": "third",
      "lookup_source": "operators",
      "strict_select": true,
      "display_fields": ["operator_id", "operator_name", "role"],
      "placeholder": "Search reporter",
      "placeholder_vi": "Tìm người báo cáo"
    },
    {
      "id": "recovery_note",
      "type": "textarea",
      "label": "Recovery Note",
      "label_vi": "Ghi chú khôi phục",
      "required": false,
      "rows": 3,
      "width": "full",
      "placeholder": "Notes for recovery, follow-up, or escalation",
      "placeholder_vi": "Ghi chú cho khôi phục, follow-up hoặc escalation"
    }
  ],
  "signature_blocks": [
    {
      "id": "reported_by",
      "label": "Reporter Signature",
      "label_vi": "Chữ ký người báo cáo",
      "label_en": "Reporter Signature",
      "help": "Confirm the downtime event details are accurate.",
      "help_vi": "Xác nhận thông tin downtime là chính xác.",
      "require_reason": false,
      "require_pin": false,
      "signature_meaning": "Downtime report confirmation",
      "signature_meaning_vi": "Xác nhận báo cáo downtime"
    },
    {
      "id": "reviewed_by",
      "label": "Recovery Review",
      "label_vi": "Chữ ký xác nhận khôi phục",
      "label_en": "Recovery Review",
      "help": "Review the root cause and recovery action before closure.",
      "help_vi": "Xem xét nguyên nhân gốc và hành động khôi phục trước khi đóng sự kiện.",
      "require_reason": true,
      "require_pin": true,
      "signature_meaning": "Downtime recovery review",
      "signature_meaning_vi": "Xác nhận khôi phục downtime"
    }
  ],
  "approval_flow": [
    {
      "id": "reported_by",
      "signature_block_id": "reported_by",
      "requiredOnSubmit": true,
      "labelVi": "Người báo cáo",
      "labelEn": "Reporter"
    },
    {
      "id": "reviewed_by",
      "signature_block_id": "reviewed_by",
      "requiredOnSubmit": false,
      "labelVi": "Người xác nhận khôi phục",
      "labelEn": "Recovery reviewer"
    }
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"]
}
