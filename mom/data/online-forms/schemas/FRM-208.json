{
  "form_code": "FRM-208",
  "title": "Daily Tier Meeting & Escalation Log",
  "title_vi": "Nhật ký họp Tier hàng ngày & Escalation",
  "version": "V1",
  "category": "production",
  "frequency": "daily",
  "sop_ref": "SOP-501",
  "description": "Ghi nhận vấn đề phát sinh trong họp Tier hàng ngày, phân công xử lý và theo dõi đóng.",
  "roles_allowed": ["admin", "production_manager", "production_planner", "shift_leader", "qc_lead", "qa_manager", "engineering_manager"],
  "fields": [
    {
      "id": "meeting_date",
      "type": "date",
      "label": "Ngày họp",
      "label_en": "Meeting Date",
      "required": true,
      "default": "today"
    },
    {
      "id": "shift",
      "type": "select",
      "label": "Ca",
      "label_en": "Shift",
      "required": true,
      "options_source": "registry:shift_code",
      "options": [
        {"value": "1", "label": "Ca 1 (06:00–14:00)"},
        {"value": "2", "label": "Ca 2 (14:00–22:00)"},
        {"value": "3", "label": "Ca 3 (22:00–06:00)"}
      ]
    },
    {
      "id": "tier_level",
      "type": "select",
      "label": "Cấp Tier",
      "label_en": "Tier Level",
      "required": true,
      "options_source": "registry:tier_level",
      "options": [
        {"value": "T1", "label": "T1 — Operator/Team Lead (đầu ca)"},
        {"value": "T2", "label": "T2 — Shift Leader/Supervisor (giữa ca)"},
        {"value": "T3", "label": "T3 — Dept Manager (hàng ngày)"},
        {"value": "T4", "label": "T4 — Plant Manager (hàng tuần)"}
      ]
    },
    {
      "id": "department",
      "type": "select",
      "label": "Phòng ban",
      "label_en": "Department",
      "required": true,
      "options_source": "registry:dept_code",
      "options": [
        {"value": "PROD", "label": "Sản xuất"},
        {"value": "ENG", "label": "Kỹ thuật"},
        {"value": "QA", "label": "Chất lượng"},
        {"value": "SCM", "label": "Chuỗi cung ứng"},
        {"value": "SALES", "label": "Kinh doanh"},
        {"value": "FIN", "label": "Tài chính"},
        {"value": "HR", "label": "Nhân sự"},
        {"value": "IT", "label": "IT"},
        {"value": "EHS", "label": "An toàn"},
        {"value": "ALL", "label": "Toàn nhà máy"}
      ]
    },
    {
      "id": "attendees",
      "type": "text",
      "label": "Người tham dự",
      "label_en": "Attendees",
      "required": true,
      "placeholder": "Tên người tham dự, phân tách bằng dấu phẩy"
    },
    {
      "id": "kpi_snapshot",
      "type": "group",
      "label": "KPI Snapshot",
      "label_en": "KPI Snapshot",
      "fields": [
        {"id": "otd_percent", "type": "number", "label": "OTD (%)", "min": 0, "max": 100, "step": 0.1, "placeholder": "95.0"},
        {"id": "fpy_percent", "type": "number", "label": "FPY (%)", "min": 0, "max": 100, "step": 0.1, "placeholder": "98.0"},
        {"id": "wip_red_count", "type": "number", "label": "WIP Đỏ (jobs)", "min": 0, "placeholder": "0"},
        {"id": "downtime_hours", "type": "number", "label": "Downtime (giờ)", "min": 0, "step": 0.5, "placeholder": "0.0"}
      ]
    },
    {
      "id": "issues",
      "type": "table",
      "label": "Vấn đề & Hành động",
      "label_en": "Issues & Actions",
      "min_rows": 0,
      "max_rows": 20,
      "columns": [
        {"id": "issue_desc", "type": "text", "label": "Mô tả vấn đề", "width": "30%", "required": true},
        {"id": "severity", "type": "select", "label": "Mức độ", "width": "12%", "options_source": "registry:severity", "options": [
          {"value": "low", "label": "Low", "color": "#2f9e44"},
          {"value": "medium", "label": "Medium", "color": "#e67700"},
          {"value": "high", "label": "High", "color": "#e03131"},
          {"value": "critical", "label": "Critical", "color": "#862e9c"}
        ]},
        {"id": "category", "type": "select", "label": "Loại", "width": "12%", "options_source": "registry:issue_category", "options": [
          {"value": "quality", "label": "Chất lượng"},
          {"value": "machine", "label": "Máy móc"},
          {"value": "material", "label": "Vật tư"},
          {"value": "manpower", "label": "Nhân lực"},
          {"value": "method", "label": "Phương pháp"},
          {"value": "safety", "label": "An toàn"},
          {"value": "delivery", "label": "Giao hàng"},
          {"value": "other", "label": "Khác"}
        ]},
        {"id": "owner", "type": "text", "label": "Người xử lý", "width": "14%", "required": true},
        {"id": "due_date", "type": "date", "label": "Hạn", "width": "12%"},
        {"id": "status", "type": "select", "label": "Trạng thái", "width": "12%", "options": [
          {"value": "open", "label": "Open", "color": "#e03131"},
          {"value": "in_progress", "label": "In Progress", "color": "#e67700"},
          {"value": "closed", "label": "Closed", "color": "#2f9e44"}
        ]}
      ]
    },
    {
      "id": "escalation_needed",
      "type": "checkbox",
      "label": "Cần escalation lên cấp trên",
      "label_en": "Escalation needed",
      "default": false
    },
    {
      "id": "escalation_note",
      "type": "textarea",
      "label": "Ghi chú escalation",
      "label_en": "Escalation Note",
      "rows": 3,
      "show_if": {"field": "escalation_needed", "value": true},
      "placeholder": "Mô tả lý do escalation, người nhận, thời hạn..."
    },
    {
      "id": "next_actions",
      "type": "textarea",
      "label": "Hành động tiếp theo",
      "label_en": "Next Actions",
      "rows": 3,
      "placeholder": "Hành động ưu tiên cho ca/ngày tiếp theo..."
    }
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_critical": ["qa_manager", "production_manager"],
    "on_escalation": ["production_director", "ceo"]
  }
}