{
  "form_code": "FRM-513",
  "title": "Tool Life Log",
  "title_vi": "Nhật ký tuổi thọ dao",
  "version": "V1",
  "category": "production",
  "frequency": "per_event",
  "sop_ref": "SOP-503",
  "description": "Ghi nhận tuổi thọ dao cụ, tình trạng mòn và hành động thay thế nhằm theo dõi hiệu suất dao và lập kế hoạch thay dao.",
  "roles_allowed": ["admin", "production_manager", "shift_leader", "cnc_operator", "tool_crib"],
  "fields": [
    {"id": "date", "type": "date", "label": "Ngày", "label_en": "Date", "required": true, "default": "today"},
    {"id": "machine_id", "type": "text", "label": "Mã máy", "label_en": "Machine ID", "required": true, "placeholder": "VD: CNC-01"},
    {"id": "tool_id", "type": "text", "label": "Mã dao", "label_en": "Tool ID", "required": true, "placeholder": "VD: T-0012"},
    {"id": "tool_description", "type": "text", "label": "Mô tả dao", "label_en": "Tool Description", "required": true, "placeholder": "VD: Dao phay ngón D10 carbide"},
    {
      "id": "tool_type",
      "type": "select",
      "label": "Loại dao",
      "label_en": "Tool Type",
      "required": true,
      "options_source": "registry:tool_type",
      "options": [
        {"value": "end_mill", "label": "Dao phay ngón (End Mill)"},
        {"value": "face_mill", "label": "Dao phay mặt (Face Mill)"},
        {"value": "drill", "label": "Mũi khoan (Drill)"},
        {"value": "tap", "label": "Tarô (Tap)"},
        {"value": "reamer", "label": "Mũi doa (Reamer)"},
        {"value": "insert", "label": "Mảnh cắt (Insert)"},
        {"value": "boring_bar", "label": "Dao tiện lỗ (Boring Bar)"},
        {"value": "turning_tool", "label": "Dao tiện (Turning Tool)"},
        {"value": "other", "label": "Khác (Other)"}
      ]
    },
    {"id": "pocket_number", "type": "text", "label": "Vị trí dao (Pocket)", "label_en": "Pocket Number", "required": true, "placeholder": "VD: T01, T12"},
    {"id": "parts_at_change", "type": "number", "label": "Số chi tiết đã gia công", "label_en": "Parts at Change", "required": true, "min": 0},
    {"id": "tool_life_target", "type": "number", "label": "Tuổi thọ mục tiêu (chi tiết)", "label_en": "Tool Life Target (parts)", "required": true, "min": 0},
    {
      "id": "wear_condition",
      "type": "select",
      "label": "Tình trạng mòn",
      "label_en": "Wear Condition",
      "required": true,
      "options_source": "registry:wear_condition",
      "options": [
        {"value": "normal", "label": "Bình thường (Normal)", "color": "#2f9e44"},
        {"value": "worn", "label": "Mòn (Worn)", "color": "#e67700"},
        {"value": "chipped", "label": "Sứt mẻ (Chipped)", "color": "#e03131"},
        {"value": "broken", "label": "Gãy (Broken)", "color": "#e03131"}
      ]
    },
    {
      "id": "action",
      "type": "select",
      "label": "Hành động",
      "label_en": "Action",
      "required": true,
      "options_source": "registry:disposition",
      "options": [
        {"value": "replace", "label": "Thay mới (Replace)"},
        {"value": "regrind", "label": "Mài lại (Regrind)"},
        {"value": "scrap", "label": "Phế (Scrap)"}
      ]
    },
    {"id": "replacement_tool_id", "type": "text", "label": "Mã dao thay thế", "label_en": "Replacement Tool ID", "placeholder": "VD: T-0013"},
    {"id": "operator_id", "type": "text", "label": "Người vận hành", "label_en": "Operator", "required": true},
    {"id": "notes", "type": "textarea", "label": "Ghi chú", "label_en": "Notes", "rows": 3, "placeholder": "Nhận xét về tình trạng dao, nguyên nhân hỏng..."}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_broken": ["production_manager", "tool_crib"],
    "on_submit": ["tool_crib"]
  }
}
