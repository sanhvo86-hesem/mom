{
  "form_code": "FRM-641",
  "title": "Corrective & Preventive Action (CAPA)",
  "title_vi": "Hành động khắc phục và phòng ngừa (CAPA)",
  "version": "V1",
  "category": "quality",
  "frequency": "per_event",
  "sop_ref": "SOP-606",
  "description": "Ghi nhận hành động khắc phục/phòng ngừa liên kết với NCR, audit, khiếu nại khách hàng hoặc xem xét lãnh đạo.",
  "roles_allowed": ["admin", "qa_manager", "quality_engineer", "production_manager", "engineering_manager", "supply_chain_manager"],
  "fields": [
    {"id": "capa_date", "type": "date", "label": "Ngày mở CAPA", "label_en": "CAPA Date", "required": true, "default": "today"},
    {
      "id": "capa_type",
      "type": "select",
      "label": "Loại CAPA",
      "label_en": "CAPA Type",
      "required": true,
      "options": [
        {"value": "corrective", "label": "Khắc phục (Corrective)"},
        {"value": "preventive", "label": "Phòng ngừa (Preventive)"}
      ]
    },
    {
      "id": "source",
      "type": "select",
      "label": "Nguồn phát sinh",
      "label_en": "Source",
      "required": true,
      "options": [
        {"value": "ncr", "label": "NCR"},
        {"value": "audit", "label": "Đánh giá (Audit)"},
        {"value": "customer_complaint", "label": "Khiếu nại khách hàng (Customer Complaint)"},
        {"value": "management_review", "label": "Xem xét lãnh đạo (Management Review)"},
        {"value": "other", "label": "Khác (Other)"}
      ]
    },
    {"id": "source_reference", "type": "text", "label": "Mã tham chiếu nguồn", "label_en": "Source Reference", "required": true, "placeholder": "VD: NCR-2026-015, AUD-2026-IA02"},
    {
      "id": "department",
      "type": "select",
      "label": "Phòng ban liên quan",
      "label_en": "Department",
      "required": true,
      "options": [
        {"value": "PROD", "label": "Sản xuất"},
        {"value": "ENG", "label": "Kỹ thuật"},
        {"value": "QA", "label": "Chất lượng"},
        {"value": "SCM", "label": "Chuỗi cung ứng"},
        {"value": "WH", "label": "Kho vận"},
        {"value": "HR", "label": "Nhân sự"},
        {"value": "ALL", "label": "Toàn nhà máy"}
      ]
    },
    {"id": "description", "type": "textarea", "label": "Mô tả vấn đề", "label_en": "Description", "rows": 4, "required": true, "placeholder": "Mô tả vấn đề cần khắc phục/phòng ngừa..."},
    {
      "id": "root_cause_method",
      "type": "select",
      "label": "Phương pháp phân tích nguyên nhân",
      "label_en": "Root Cause Method",
      "required": true,
      "options": [
        {"value": "5why", "label": "5 Why"},
        {"value": "fishbone", "label": "Fishbone (Ishikawa)"},
        {"value": "8d", "label": "8D"},
        {"value": "is_isnot", "label": "IS / IS-NOT"}
      ]
    },
    {"id": "root_cause_analysis", "type": "textarea", "label": "Phân tích nguyên nhân gốc", "label_en": "Root Cause Analysis", "rows": 5, "required": true, "placeholder": "Kết quả phân tích nguyên nhân gốc..."},
    {"id": "immediate_action", "type": "textarea", "label": "Hành động tức thời", "label_en": "Immediate Action", "rows": 3, "placeholder": "Hành động ngăn chặn/xử lý tức thời..."},
    {"id": "corrective_action", "type": "textarea", "label": "Hành động khắc phục", "label_en": "Corrective Action", "rows": 3, "required": true, "placeholder": "Hành động để loại bỏ nguyên nhân gốc..."},
    {"id": "preventive_action", "type": "textarea", "label": "Hành động phòng ngừa", "label_en": "Preventive Action", "rows": 3, "placeholder": "Hành động để ngăn ngừa tái phát..."},
    {"id": "responsible_person", "type": "text", "label": "Người chịu trách nhiệm", "label_en": "Responsible Person", "required": true},
    {"id": "target_date", "type": "date", "label": "Ngày mục tiêu hoàn thành", "label_en": "Target Date", "required": true},
    {"id": "completion_date", "type": "date", "label": "Ngày hoàn thành thực tế", "label_en": "Completion Date", "required": false},
    {"id": "verification_method", "type": "text", "label": "Phương pháp xác nhận", "label_en": "Verification Method", "placeholder": "VD: Kiểm tra 3 lô tiếp theo, audit hiện trường"},
    {"id": "verification_result", "type": "textarea", "label": "Kết quả xác nhận", "label_en": "Verification Result", "rows": 3},
    {"id": "effectiveness_check_date", "type": "date", "label": "Ngày kiểm tra hiệu lực", "label_en": "Effectiveness Check Date"},
    {"id": "effectiveness_result", "type": "textarea", "label": "Kết quả kiểm tra hiệu lực", "label_en": "Effectiveness Result", "rows": 3, "placeholder": "Kết quả đánh giá hiệu lực sau 30-90 ngày..."},
    {
      "id": "status",
      "type": "select",
      "label": "Trạng thái",
      "label_en": "Status",
      "required": true,
      "default": "open",
      "options": [
        {"value": "open", "label": "Mở (Open)", "color": "#e03131"},
        {"value": "investigation", "label": "Đang điều tra (Investigation)", "color": "#e67700"},
        {"value": "action_implementation", "label": "Đang triển khai (Implementation)", "color": "#1971c2"},
        {"value": "verification", "label": "Đang xác nhận (Verification)", "color": "#862e9c"},
        {"value": "effectiveness_review", "label": "Đang kiểm tra hiệu lực (Effectiveness)", "color": "#0369a1"},
        {"value": "closed", "label": "Đã đóng (Closed)", "color": "#2f9e44"}
      ]
    },
    {"id": "approved_by", "type": "text", "label": "Người phê duyệt", "label_en": "Approved By", "required": false}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "evidence_requirements": [
    {
      "id": "capa_action_completion",
      "kind": "fields_present",
      "label": "CAPA completion evidence captured",
      "label_vi": "Bằng chứng hoàn tất CAPA đã được ghi nhận",
      "field_ids": ["completion_date", "verification_method", "verification_result"],
      "required_stages": ["approval"]
    },
    {
      "id": "capa_effectiveness_review",
      "kind": "capa_effectiveness",
      "label": "CAPA effectiveness verified",
      "label_vi": "Hiệu lực CAPA đã được kiểm tra",
      "completion_field": "completion_date",
      "verification_method_field": "verification_method",
      "verification_result_field": "verification_result",
      "effectiveness_date_field": "effectiveness_check_date",
      "effectiveness_result_field": "effectiveness_result",
      "status_field": "status",
      "allowed_statuses": ["closed"],
      "min_days_after": 30,
      "max_days_after": 90,
      "required_stages": ["approval"]
    }
  ],
  "notifications": {
    "on_overdue": ["qa_manager", "responsible_person"],
    "on_submit": ["qa_manager"]
  }
}
