{
  "form_code": "FRM-701",
  "title": "Receiving Inspection Log",
  "title_vi": "Nhật ký kiểm tra hàng nhận",
  "version": "V1",
  "category": "quality",
  "frequency": "per_event",
  "sop_ref": "SOP-701",
  "description": "Ghi nhận kết quả kiểm tra nguyên vật liệu và hàng hoá nhận từ nhà cung cấp tại kho nhận hàng.",
  "roles_allowed": ["admin", "qa_manager", "qc_inspector", "warehouse_staff", "supply_chain_manager"],
  "fields": [
    {"id": "receive_date", "type": "date", "label": "Ngày nhận hàng", "label_en": "Receive Date", "required": true, "default": "today"},
    {"id": "supplier_name", "type": "text", "label": "Tên nhà cung cấp", "label_en": "Supplier Name", "required": true},
    {"id": "supplier_id", "type": "text", "label": "Mã nhà cung cấp", "label_en": "Supplier ID"},
    {"id": "po_number", "type": "text", "label": "Số PO", "label_en": "PO Number", "required": true},
    {"id": "delivery_note", "type": "text", "label": "Số phiếu giao hàng", "label_en": "Delivery Note No.", "placeholder": "Số DN / packing list từ NCC"},
    {
      "id": "line_items",
      "type": "table",
      "label": "Danh sách hàng nhận",
      "label_en": "Line Items",
      "min_rows": 1,
      "max_rows": 30,
      "columns": [
        {"id": "part_number", "type": "text", "label": "Mã chi tiết / vật tư", "width": "18%", "required": true},
        {"id": "description", "type": "text", "label": "Mô tả", "width": "18%"},
        {"id": "lot_heat_no", "type": "text", "label": "Số lô / Heat No.", "width": "14%"},
        {"id": "qty_ordered", "type": "text", "label": "SL đặt", "width": "8%"},
        {"id": "qty_received", "type": "text", "label": "SL nhận", "width": "8%", "required": true},
        {"id": "qty_accepted", "type": "text", "label": "SL đạt", "width": "8%"},
        {"id": "qty_rejected", "type": "text", "label": "SL loại", "width": "8%"},
        {"id": "result", "type": "select", "label": "Kết quả", "width": "12%", "options": [
          {"value": "accept", "label": "Đạt", "color": "#2f9e44"},
          {"value": "reject", "label": "Loại bỏ", "color": "#e03131"},
          {"value": "conditional", "label": "Có ĐK", "color": "#e67700"},
          {"value": "pending", "label": "Chờ", "color": "#868e96"}
        ]}
      ]
    },
    {
      "id": "packaging_condition",
      "type": "select",
      "label": "Tình trạng bao bì",
      "label_en": "Packaging Condition",
      "required": true,
      "options": [
        {"value": "good", "label": "Tốt (Good)", "color": "#2f9e44"},
        {"value": "damaged", "label": "Bị hư hại (Damaged)", "color": "#e03131"},
        {"value": "acceptable", "label": "Chấp nhận được (Acceptable)", "color": "#e67700"}
      ]
    },
    {
      "id": "certs_received",
      "type": "select",
      "label": "Chứng chỉ đi kèm",
      "label_en": "Certificates Received",
      "required": true,
      "options": [
        {"value": "complete", "label": "Đầy đủ (Complete)", "color": "#2f9e44"},
        {"value": "partial", "label": "Thiếu (Partial)", "color": "#e67700"},
        {"value": "none", "label": "Không có (None)", "color": "#e03131"},
        {"value": "na", "label": "N/A", "color": "#868e96"}
      ]
    },
    {"id": "cert_details", "type": "text", "label": "Chi tiết chứng chỉ", "label_en": "Certificate Details", "placeholder": "VD: Mill cert, CoC, test report"},
    {
      "id": "dimensional_check",
      "type": "select",
      "label": "Kiểm tra kích thước",
      "label_en": "Dimensional Check",
      "options": [
        {"value": "pass", "label": "Đạt (Pass)", "color": "#2f9e44"},
        {"value": "fail", "label": "Không đạt (Fail)", "color": "#e03131"},
        {"value": "na", "label": "N/A", "color": "#868e96"}
      ]
    },
    {
      "id": "material_verification",
      "type": "select",
      "label": "Xác nhận vật liệu",
      "label_en": "Material Verification",
      "options": [
        {"value": "verified", "label": "Đã xác nhận (Verified)", "color": "#2f9e44"},
        {"value": "not_verified", "label": "Chưa xác nhận (Not Verified)", "color": "#e67700"},
        {"value": "na", "label": "N/A", "color": "#868e96"}
      ]
    },
    {
      "id": "overall_disposition",
      "type": "select",
      "label": "Quyết định xử lý",
      "label_en": "Overall Disposition",
      "required": true,
      "options": [
        {"value": "accept", "label": "Chấp nhận nhập kho (Accept)", "color": "#2f9e44"},
        {"value": "reject_return", "label": "Từ chối trả NCC (Reject & Return)", "color": "#e03131"},
        {"value": "hold", "label": "Giữ lại chờ xử lý (Hold)", "color": "#e67700"},
        {"value": "conditional_accept", "label": "Chấp nhận có điều kiện (Conditional)", "color": "#1971c2"}
      ]
    },
    {"id": "ncr_number", "type": "text", "label": "Số NCR (nếu có)", "label_en": "NCR Number"},
    {"id": "inspected_by", "type": "text", "label": "Người kiểm tra", "label_en": "Inspected By", "required": true},
    {"id": "received_by", "type": "text", "label": "Người nhận hàng", "label_en": "Received By", "required": true},
    {"id": "notes", "type": "textarea", "label": "Ghi chú", "label_en": "Notes", "rows": 3, "placeholder": "Các lưu ý về lô hàng..."}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_reject": ["qa_manager", "supply_chain_manager"],
    "on_submit": ["qa_manager", "warehouse_staff"]
  }
}
