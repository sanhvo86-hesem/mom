{
  "form_code": "FRM-525",
  "title": "Gage Equipment Register",
  "title_vi": "Sổ đăng ký thiết bị đo",
  "version": "V1",
  "category": "quality",
  "frequency": "periodic",
  "sop_ref": "SOP-601",
  "description": "Sổ đăng ký và quản lý thiết bị đo lường, theo dõi trạng thái hiệu chuẩn và lịch hiệu chuẩn định kỳ.",
  "roles_allowed": ["admin", "quality_manager", "qc_inspector", "calibration_tech", "metrology_lab"],
  "fields": [
    {"id": "register_date", "type": "date", "label": "Ngày đăng ký", "label_en": "Register Date", "required": true, "default": "today"},
    {"id": "gage_id", "type": "text", "label": "Mã thiết bị đo", "label_en": "Gage ID", "required": true, "placeholder": "VD: GA-0001"},
    {"id": "gage_description", "type": "text", "label": "Mô tả thiết bị", "label_en": "Gage Description", "required": true, "placeholder": "VD: Thước cặp điện tử 150mm"},
    {
      "id": "gage_type",
      "type": "select",
      "label": "Loại thiết bị",
      "label_en": "Gage Type",
      "required": true,
      "options_source": "registry:gage_type",
      "options": [
        {"value": "caliper", "label": "Thước cặp (Caliper)"},
        {"value": "micrometer", "label": "Panme (Micrometer)"},
        {"value": "indicator", "label": "Đồng hồ so (Indicator)"},
        {"value": "height_gage", "label": "Thước đo cao (Height Gage)"},
        {"value": "pin_gage", "label": "Pin gage / Go-NoGo"},
        {"value": "ring_gage", "label": "Ring Gage"},
        {"value": "thread_gage", "label": "Dưỡng ren (Thread Gage)"},
        {"value": "cmm_probe", "label": "Đầu dò CMM (CMM Probe)"},
        {"value": "surface_plate", "label": "Bàn mát (Surface Plate)"},
        {"value": "force_gage", "label": "Lực kế (Force Gage)"},
        {"value": "hardness_tester", "label": "Máy đo độ cứng (Hardness Tester)"},
        {"value": "other", "label": "Khác (Other)"}
      ]
    },
    {"id": "manufacturer", "type": "text", "label": "Nhà sản xuất", "label_en": "Manufacturer", "placeholder": "VD: Mitutoyo, Starrett"},
    {"id": "model", "type": "text", "label": "Model", "label_en": "Model"},
    {"id": "serial_number", "type": "text", "label": "Số serial", "label_en": "Serial Number", "required": true},
    {"id": "range", "type": "text", "label": "Phạm vi đo", "label_en": "Range", "required": true, "placeholder": "VD: 0-150mm"},
    {"id": "resolution", "type": "text", "label": "Độ phân giải", "label_en": "Resolution", "required": true, "placeholder": "VD: 0.01mm"},
    {"id": "location", "type": "text", "label": "Vị trí", "label_en": "Location", "required": true, "placeholder": "VD: Xưởng CNC - Khu A, Phòng QC"},
    {
      "id": "status",
      "type": "select",
      "label": "Trạng thái",
      "label_en": "Status",
      "required": true,
      "options_source": "registry:gage_status",
      "options": [
        {"value": "active", "label": "Đang sử dụng (Active)", "color": "#2f9e44"},
        {"value": "due_calibration", "label": "Sắp đến hạn hiệu chuẩn", "color": "#e67700"},
        {"value": "overdue", "label": "Quá hạn hiệu chuẩn (Overdue)", "color": "#e03131"},
        {"value": "out_of_service", "label": "Ngừng sử dụng (Out of Service)", "color": "#868e96"},
        {"value": "scrapped", "label": "Thanh lý (Scrapped)", "color": "#495057"}
      ]
    },
    {"id": "last_calibration_date", "type": "date", "label": "Ngày hiệu chuẩn gần nhất", "label_en": "Last Calibration Date", "required": true},
    {"id": "next_due_date", "type": "date", "label": "Ngày hiệu chuẩn tiếp theo", "label_en": "Next Due Date", "required": true},
    {"id": "calibration_interval_months", "type": "number", "label": "Chu kỳ hiệu chuẩn (tháng)", "label_en": "Calibration Interval (months)", "required": true, "min": 1, "max": 60},
    {"id": "responsible_person", "type": "text", "label": "Người chịu trách nhiệm", "label_en": "Responsible Person", "required": true}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_overdue": ["quality_manager", "calibration_tech"],
    "on_submit": ["quality_manager"]
  }
}
