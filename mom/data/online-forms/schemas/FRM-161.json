{
  "form_code": "FRM-161",
  "title": "Engineering Change Request (ECR)",
  "title_vi": "Yêu cầu thay đổi kỹ thuật (ECR)",
  "version": "V1",
  "category": "quality",
  "frequency": "per_event",
  "sop_ref": "SOP-106",
  "description": "Yêu cầu chính thức thay đổi kỹ thuật đối với chi tiết, quy trình, tooling hoặc tài liệu, bao gồm đánh giá tác động và phê duyệt.",
  "roles_allowed": ["admin", "engineering_manager", "process_engineer", "dfm_engineer", "qa_manager", "production_manager"],
  "fields": [
    {"id": "ecr_date", "type": "date", "label": "Ngày yêu cầu", "label_en": "ECR Date", "required": true, "default": "today"},
    {
      "id": "ecr_type",
      "type": "select",
      "label": "Loại thay đổi",
      "label_en": "ECR Type",
      "required": true,
      "options_source": "registry:ecr_type",
      "options": [
        {"value": "design", "label": "Thiết kế (Design)"},
        {"value": "process", "label": "Quy trình (Process)"},
        {"value": "material", "label": "Vật liệu (Material)"},
        {"value": "tooling", "label": "Tooling"},
        {"value": "documentation", "label": "Tài liệu (Documentation)"}
      ]
    },
    {
      "id": "department",
      "type": "select",
      "label": "Phòng ban yêu cầu",
      "label_en": "Department",
      "required": true,
      "options_source": "registry:dept_code",
      "options": [
        {"value": "ENG", "label": "Kỹ thuật"},
        {"value": "PROD", "label": "Sản xuất"},
        {"value": "QA", "label": "Chất lượng"},
        {"value": "SCM", "label": "Chuỗi cung ứng"},
        {"value": "SALES", "label": "Kinh doanh"}
      ]
    },
    {"id": "requestor", "type": "text", "label": "Người yêu cầu", "label_en": "Requestor", "required": true},
    {"id": "part_number", "type": "text", "label": "Mã chi tiết", "label_en": "Part Number", "required": true},
    {"id": "part_rev", "type": "text", "label": "Revision hiện tại", "label_en": "Part Revision"},
    {"id": "current_revision", "type": "text", "label": "Revision hiện tại (tài liệu)", "label_en": "Current Revision", "required": true},
    {"id": "proposed_revision", "type": "text", "label": "Revision đề xuất", "label_en": "Proposed Revision", "required": true},
    {"id": "change_description", "type": "textarea", "label": "Mô tả thay đổi", "label_en": "Change Description", "rows": 5, "required": true, "placeholder": "Mô tả chi tiết nội dung thay đổi..."},
    {
      "id": "reason_for_change",
      "type": "select",
      "label": "Lý do thay đổi",
      "label_en": "Reason for Change",
      "required": true,
      "options_source": "registry:reason_for_change",
      "options": [
        {"value": "customer_request", "label": "Yêu cầu khách hàng (Customer Request)"},
        {"value": "quality_improvement", "label": "Cải thiện chất lượng (Quality Improvement)"},
        {"value": "cost_reduction", "label": "Giảm chi phí (Cost Reduction)"},
        {"value": "process_improvement", "label": "Cải tiến quy trình (Process Improvement)"},
        {"value": "corrective_action", "label": "Hành động khắc phục (Corrective Action)"},
        {"value": "regulatory", "label": "Yêu cầu pháp luật (Regulatory)"}
      ]
    },
    {
      "id": "affected_documents",
      "type": "table",
      "label": "Tài liệu bị ảnh hưởng",
      "label_en": "Affected Documents",
      "min_rows": 1,
      "max_rows": 20,
      "columns": [
        {"id": "doc_type", "type": "text", "label": "Loại tài liệu", "width": "20%", "required": true, "placeholder": "VD: Drawing, SOP, WI"},
        {"id": "doc_number", "type": "text", "label": "Mã tài liệu", "width": "25%", "required": true},
        {"id": "current_rev", "type": "text", "label": "Rev hiện tại", "width": "15%"},
        {"id": "new_rev", "type": "text", "label": "Rev mới", "width": "15%"}
      ]
    },
    {"id": "affected_processes", "type": "textarea", "label": "Quy trình bị ảnh hưởng", "label_en": "Affected Processes", "rows": 3, "placeholder": "Liệt kê các quy trình/công đoạn bị ảnh hưởng..."},
    {"id": "impact_assessment", "type": "textarea", "label": "Đánh giá tác động", "label_en": "Impact Assessment", "rows": 4, "required": true, "placeholder": "Đánh giá tác động đến chất lượng, chi phí, tiến độ, an toàn..."},
    {"id": "risk_assessment", "type": "textarea", "label": "Đánh giá rủi ro", "label_en": "Risk Assessment", "rows": 3, "placeholder": "Rủi ro liên quan đến thay đổi..."},
    {"id": "validation_required", "type": "checkbox", "label": "Yêu cầu xác nhận (Validation)", "label_en": "Validation Required", "default": false},
    {"id": "validation_plan", "type": "textarea", "label": "Kế hoạch xác nhận", "label_en": "Validation Plan", "rows": 3, "show_if": {"field": "validation_required", "value": true}, "placeholder": "Kế hoạch FAI, kiểm tra, thử nghiệm..."},
    {"id": "implementation_date", "type": "date", "label": "Ngày triển khai", "label_en": "Implementation Date"},
    {"id": "approved_by", "type": "text", "label": "Người phê duyệt", "label_en": "Approved By"},
    {"id": "engineering_review", "type": "textarea", "label": "Xem xét kỹ thuật", "label_en": "Engineering Review", "rows": 2, "placeholder": "Ý kiến của phòng Kỹ thuật..."},
    {"id": "quality_review", "type": "textarea", "label": "Xem xét chất lượng", "label_en": "Quality Review", "rows": 2, "placeholder": "Ý kiến của phòng Chất lượng..."},
    {"id": "production_review", "type": "textarea", "label": "Xem xét sản xuất", "label_en": "Production Review", "rows": 2, "placeholder": "Ý kiến của phòng Sản xuất..."},
    {"id": "customer_notification_required", "type": "checkbox", "label": "Cần thông báo khách hàng", "label_en": "Customer Notification Required", "default": false}
  ],
  "evidence_review": {
    "approval_mode": "parallel",
    "minimum_approvals": 2,
    "roles_allowed": ["admin", "engineering_manager", "qa_manager", "production_manager"],
    "label_vi": "Phê duyệt liên phòng ban",
    "label_en": "Cross-functional approval"
  },
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_submit": ["engineering_manager", "qa_manager"],
    "on_customer_impact": ["sales_manager", "ceo"]
  }
}
