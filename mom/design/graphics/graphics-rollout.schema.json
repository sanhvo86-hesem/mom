{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Graphics Rollout",
  "type": "object",
  "required": [
    "rolloutId",
    "state",
    "scope",
    "changeSetId"
  ],
  "properties": {
    "rolloutId": {
      "type": "string"
    },
    "state": {
      "enum": [
        "preview-only",
        "draft-saved",
        "validated",
        "staged",
        "publish-blocked",
        "applied",
        "rolled-back",
        "waived"
      ]
    },
    "scope": {
      "type": "object"
    },
    "changeSetId": {
      "type": "string"
    }
  }
}