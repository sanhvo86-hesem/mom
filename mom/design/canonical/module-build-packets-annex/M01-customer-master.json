{
  "moduleProfile": {
    "purpose": "Maintain authoritative customer account, contractual, shipping, commercial and quality requirement data.",
    "workflowNote": "Customer master changes require controlled review when they affect commercial terms, compliance flags or quality clauses.",
    "personas": [
      "Sales admin",
      "Sales manager",
      "Customer quality engineer",
      "Finance credit controller"
    ],
    "inputs": [
      "Customer onboarding request",
      "Legal entity profile",
      "Address/contact records",
      "Commercial terms",
      "Customer quality requirements",
      "Credit approval decision",
      "Approved product/customer link"
    ],
    "outputs": [
      "Released customer master record",
      "Commercial term set",
      "Credit status",
      "Customer-specific quality requirement profile",
      "Audit trail for changes",
      "Lookup data for quotations/orders/complaints"
    ],
    "coreScreensNarrative": [
      "Customer list",
      "Customer detail",
      "Commercial terms tab",
      "Quality requirements tab",
      "Credit status tab",
      "Related documents tab",
      "Change history tab"
    ],
    "policiesNarrative": "Freshness: erp-reference Offline: read_only Regulated: false"
  },
