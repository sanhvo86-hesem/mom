{
  "moduleProfile": {
    "purpose": "Capture, triage, investigate and close customer complaints with linkage to NCR, CAPA and shipment history.",
    "workflowNote": "Complaint records are controlled quality records. Closure may require customer response package and CAPA linkage.",
