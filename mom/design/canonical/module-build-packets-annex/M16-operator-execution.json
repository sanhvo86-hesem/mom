{
  "moduleProfile": {
    "purpose": "Guide point-of-use execution with current job, step instructions, scan/entry, hold/escalation and completion recording.",
    "workflowNote": "This module is shopfloor-critical, scanner-first and must fail closed for unsafe or stale commands.",
    "personas": [
      "Operator",
      "Line leader",
      "Supervisor"
    ],
    "inputs": [
      "Released dispatch/task",
      "Traveler/BOM/routing",
      "Work instructions",
      "Tool/material verification",
      "Barcode/serial scans"
    ],
    "outputs": [
      "Execution events",
      "Operation completion",
      "Exceptions/holds",
      "Production counts",
      "Traceability records"
    ],
    "coreScreensNarrative": [
      "Current task",
      "Instruction panel",
      "Scan/input area",
      "Large action bar",
      "Exception drawer",
      "Completion summary"
    ],
    "policiesNarrative": "Freshness: machine-heartbeat Offline: limited_capture_only Regulated: false"
  },
