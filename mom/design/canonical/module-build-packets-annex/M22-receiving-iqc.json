{
  "moduleProfile": {
    "purpose": "Inspect incoming material against sampling plan, specs and supplier status before release to stock.",
    "workflowNote": "IQC decision controls inventory release and must remain audit-reconstructable.",
    "personas": [
      "IQC inspector",
      "Receiver",
      "Quality lead"
    ],
    "inputs": [
      "Receipt lot",
      "Sampling plan",
      "Inspection spec",
      "Measurement results",
      "Disposition decision"
    ],
    "outputs": [
      "IQC record",
      "Accept/reject/hold disposition",
      "Supplier quality signal",
      "Stock release/hold update",
      "Audit trail"
    ],
    "coreScreensNarrative": [
      "IQC queue",
      "Inspection form",
      "Sampling detail",
      "Disposition panel",
      "Linked supplier/PO context",
      "Audit history"
    ],
    "policiesNarrative": "Freshness: inspection-spec Offline: limited_capture_only Regulated: true"
  },
