{
  "moduleProfile": {
    "purpose": "Capture and review in-process inspection evidence against active operation specifications before execution can proceed.",
    "workflowNote": "In-process inspection decisions must stay tied to the work order operation, inspection plan, measurement evidence, NCR escalation, and audit trail.",
    "personas": [
      "In-process inspector",
      "Operator",
      "Quality lead"
    ],
    "inputs": [
      "Work order operation",
      "Inspection plan",
      "Characteristic requirements",
      "Measurement results",
      "Disposition decision"
    ],
    "outputs": [
      "In-process inspection record",
      "Accepted/rejected/hold disposition",
      "NCR escalation signal",
      "Operation quality gate result",
      "Audit trail"
    ],
    "coreScreensNarrative": [
      "Inspection queue",
      "Execution form",
      "Characteristic grid",
      "Escalation panel",
      "History"
    ],
    "policiesNarrative": "Freshness: execution-real-time Offline: limited_capture_only Regulated: true"
  },
