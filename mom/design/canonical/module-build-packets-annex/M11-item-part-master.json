{
  "moduleProfile": {
    "purpose": "Maintain item, part, UOM, commodity, revision and planning attributes used across ERP/MOM/MES/eQMS.",
    "workflowNote": "Released item master controls downstream planning, purchasing and traceability.",
    "personas": [
      "Master data engineer",
      "Manufacturing engineer",
      "Planner",
      "Buyer"
    ],
    "inputs": [
      "Engineering release",
      "Customer requirement",
      "Commodity/classification",
      "UOM and planning rules",
      "Regulatory flags"
    ],
    "outputs": [
      "Released item master",
      "Revision-controlled metadata",
      "Planning defaults",
      "Commodity maps",
      "Downstream lookup record"
    ],
    "coreScreensNarrative": [
      "Item list",
      "Item detail",
      "Planning tab",
      "Compliance tab",
      "Related revisions",
      "Change history"
    ],
    "policiesNarrative": "Freshness: erp-reference Offline: read_only Regulated: false"
  },
