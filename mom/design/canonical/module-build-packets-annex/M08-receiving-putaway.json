{
  "moduleProfile": {
    "purpose": "Receive inbound material, validate against ASN/PO, route to IQC or stock, and complete putaway.",
    "workflowNote": "Execution is scan-heavy and must support barcode-first flow with strong duplicate/mismatch handling.",
    "personas": [
      "Receiver",
      "Warehouse clerk",
      "IQC inspector"
    ],
    "inputs": [
      "ASN/PO",
      "Supplier delivery",
      "Barcode scan",
      "Location master",
      "IQC route rules"
    ],
    "outputs": [
      "Receipt transaction",
      "Putaway task",
      "Hold/IQC routing",
      "Inventory balance update",
      "Dock-to-stock metrics"
    ],
    "coreScreensNarrative": [
      "Inbound queue",
      "Receipt execution",
      "Scan panel",
      "Disposition panel",
      "Putaway tasks",
      "Exception log"
    ],
    "policiesNarrative": "Freshness: warehouse-real-time Offline: draft_capture_only Regulated: false"
  },
