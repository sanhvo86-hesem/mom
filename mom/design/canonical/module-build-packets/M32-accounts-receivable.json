  "workflow": {
    "states": [
      "new",
      "ready_to_bill",
      "exception",
      "approved",
      "posted",
      "paid",
      "voided"
    ],
    "transitions": [
      {
        "action": "validate",
        "transition": "new -> ready_to_bill"
      },
      {
        "action": "exception",
        "transition": "ready_to_bill -> exception"
      },
      {
        "action": "approve",
        "transition": "ready_to_bill|exception -> approved"
      },
      {
        "action": "post",
        "transition": "approved -> posted"
      },
      {
        "action": "void",
        "transition": "new|ready_to_bill|exception -> voided"
      }
    ]
  },
