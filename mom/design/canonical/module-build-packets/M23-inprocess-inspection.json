      {
        "action": "accept",
        "transition": "pending_review -> accepted"
      },
      {
        "action": "reject",
        "transition": "pending_review -> rejected"
      },
      {
        "action": "hold",
        "transition": "running|pending_review -> hold"
      }
    ]
  },
