    "m19.tool.management.export"
  ],
  "workflow": {
    "states": [
      "available",
      "issued",
      "in_use",
      "due_for_change",
      "quarantined",
      "retired"
    ],
    "transitions": [
      {
        "action": "issue",
        "transition": "available -> issued"
      },
      {
        "action": "inUse",
        "transition": "issued -> in_use"
      },
      {
        "action": "dueForChange",
        "transition": "in_use -> due_for_change"
      },
      {
        "action": "quarantine",
        "transition": "available|issued|in_use -> quarantined"
      },
      {
        "action": "retire",
        "transition": "quarantined -> retired"
      }
    ]
  },
  "permissions": {
    "permissions": [
      "tool.read",
      "tool.issue",
      "tool.recordUsage",
      "tool.replace",
      "tool.export"
    ],
    "negativeTestsRequired": true,
    "fieldMaskingRequired": true
  },
  "audit": {
