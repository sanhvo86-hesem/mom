      {
        "action": "start",
        "transition": "ready -> running"
      },
      {
        "action": "pause",
        "transition": "running -> paused"
      },
      {
        "action": "hold",
        "transition": "running|paused -> hold"
      },
      {
        "action": "resume",
        "transition": "paused|hold -> running"
      },
      {
        "action": "complete",
        "transition": "running -> completed"
      },
      {
        "action": "reportIssue",
        "transition": "running|paused|hold -> exception"
      }
    ]
  },
