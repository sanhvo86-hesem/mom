  "workflow": {
    "states": [
      "draft",
      "in_review",
      "approved",
      "effective",
      "superseded",
      "obsolete"
    ],
    "transitions": [
      {
        "action": "submitReview",
        "transition": "draft -> in_review"
      },
      {
        "action": "approve",
        "transition": "in_review -> approved"
      },
      {
        "action": "release",
        "transition": "approved -> effective"
      },
      {
        "action": "supersede",
        "transition": "effective -> superseded"
      },
      {
        "action": "obsolete",
        "transition": "superseded -> obsolete"
      }
    ]
  },
  "permissions": {
    "permissions": [
      "document.read",
      "document.create",
      "document.review",
      "document.approve",
      "document.release",
      "document.sign",
      "document.export"
    ],
    "negativeTestsRequired": true,
    "fieldMaskingRequired": true
