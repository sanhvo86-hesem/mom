    "transitions": [
      {
        "action": "start",
        "transition": "planned -> in_execution"
      },
      {
        "action": "issueReport",
        "transition": "in_execution -> issued"
      },
      {
        "action": "followup",
        "transition": "issued -> followup_open"
      },
      {
        "action": "closeAudit",
        "transition": "followup_open -> closed"
      }
    ]
  },
