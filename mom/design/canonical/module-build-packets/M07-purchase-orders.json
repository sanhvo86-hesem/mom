  "workflow": {
    "states": [
      "draft",
      "pending_approval",
      "released",
      "acknowledged",
      "partially_received",
      "closed",
      "cancelled"
    ],
    "transitions": [
      {
        "action": "submitApproval",
        "transition": "draft -> pending_approval"
      },
      {
        "action": "approve",
        "transition": "pending_approval -> released"
      },
      {
        "action": "acknowledge",
        "transition": "released -> acknowledged"
      },
      {
        "action": "close",
        "transition": "partially_received|acknowledged -> closed"
      },
      {
        "action": "cancel",
        "transition": "draft|pending_approval -> cancelled"
      }
    ]
  },
