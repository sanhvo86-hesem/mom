    "transitions": [
      {
        "action": "triage",
        "transition": "new -> triaged"
      },
      {
        "action": "startInvestigation",
        "transition": "triaged -> investigating"
      },
      {
        "action": "issueResponse",
        "transition": "investigating -> customer_response_pending"
      },
      {
        "action": "close",
        "transition": "customer_response_pending -> closed"
      },
      {
        "action": "void",
        "transition": "new|triaged -> voided"
      }
    ]
  },
