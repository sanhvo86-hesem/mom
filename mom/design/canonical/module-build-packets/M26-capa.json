  "workflow": {
    "states": [
      "new",
      "analysis",
      "action_open",
      "verification_pending",
      "closed",
      "cancelled"
    ],
    "transitions": [
      {
        "action": "startAnalysis",
        "transition": "new -> analysis"
      },
      {
        "action": "assignAction",
        "transition": "analysis -> action_open"
      },
      {
        "action": "submitVerification",
        "transition": "action_open -> verification_pending"
      },
      {
        "action": "close",
        "transition": "verification_pending -> closed"
      },
      {
        "action": "cancel",
        "transition": "new|analysis -> cancelled"
      }
    ]
  },
