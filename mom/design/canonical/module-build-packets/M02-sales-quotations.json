  "workflow": {
    "states": [
      "draft",
      "priced",
      "pending_approval",
      "released",
      "expired",
      "cancelled"
    ],
    "transitions": [
      {
        "action": "price",
        "transition": "draft -> priced"
      },
      {
        "action": "submitApproval",
        "transition": "priced -> pending_approval"
      },
      {
        "action": "approve",
        "transition": "pending_approval -> released"
      },
      {
        "action": "expire",
        "transition": "released -> expired"
      },
      {
        "action": "cancel",
        "transition": "draft|priced|pending_approval -> cancelled"
      }
    ]
  },
  "permissions": {
    "permissions": [
      "quotation.read",
      "quotation.create",
