{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hesem.local/schemas/module-build-packet.schema.json",
  "title": "HESEM Frontend Module Build Packet",
  "type": "object",
  "required": [
    "moduleId",
    "moduleName",
    "route",
    "domain",
    "criticality",
    "ownerTeam",
    "processOwner",
    "primaryEntity",
    "contractRefs",
    "moduleArchetype",
    "version",
    "templateId",
    "templateVersion",
    "zones",
    "screens",
    "blocks",
    "apiBindings",
    "workflows",
    "permissions",
    "regulatoryScope",
    "audit",
    "i18n",
    "densityModes",
    "responsive",
    "offlineSupport",
    "printSupport",
    "accessibility",
    "performance",
    "performanceBudget",
    "qa",
    "traceability",
    "releaseDate"
  ],
  "additionalProperties": true,
  "properties": {
    "moduleId": { "type": "string" },
    "moduleName": { "type": "object" },
    "route": { "type": "string" },
    "domain": { "type": "string" },
    "criticality": { "type": "string" },
    "ownerTeam": { "type": "string" },
    "processOwner": { "type": "string" },
    "primaryEntity": { "type": "string" },
    "contractRefs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "moduleArchetype": { "type": "string" },
    "version": { "type": "string" },
    "templateId": { "type": "string" },
    "templateVersion": { "type": "string" },
    "zones": { "type": "object" },
    "screens": { "type": "array", "minItems": 1 },
    "blocks": { "type": "array", "minItems": 1 },
    "apiBindings": { "type": "array" },
    "workflows": { "type": "array" },
    "permissions": { "type": "object" },
    "regulatoryScope": { "type": "array", "items": { "type": "string" } },
    "audit": { "type": "object" },
    "i18n": { "type": "object" },
    "densityModes": { "type": "array", "items": { "type": "string" } },
    "responsive": { "type": "object" },
    "offlineSupport": { "type": "object" },
    "printSupport": { "type": "object" },
    "accessibility": { "type": "object" },
    "performance": { "type": "object" },
    "performanceBudget": { "type": "object" },
    "qa": { "type": "object" },
    "traceability": { "type": "object" },
    "releaseDate": { "type": "string" }
  }
}
