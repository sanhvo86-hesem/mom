{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hesem.local/schemas/graphics-governance.schema.json",
  "title": "HESEM Graphics Governance Backend Contracts",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "DesignConfig": { "$ref": "#/$defs/DesignConfig" },
    "TemplateRegistryEntry": { "$ref": "#/$defs/TemplateRegistryEntry" },
    "TemplateRegistryCollection": { "$ref": "#/$defs/TemplateRegistryCollection" },
    "TemplateDraft": { "$ref": "#/$defs/TemplateDraft" },
    "TemplateValidationResult": { "$ref": "#/$defs/TemplateValidationResult" },
    "GraphicsImpactReport": { "$ref": "#/$defs/GraphicsImpactReport" },
    "ModuleGraphicsComplianceEntry": { "$ref": "#/$defs/ModuleGraphicsComplianceEntry" },
    "GraphicsDebtReport": { "$ref": "#/$defs/GraphicsDebtReport" },
    "graphicsDebtReport": { "$ref": "#/$defs/GraphicsDebtReport" },
    "GraphicsDriftReport": { "$ref": "#/$defs/GraphicsDriftReport" },
    "graphicsDriftReport": { "$ref": "#/$defs/GraphicsDriftReport" },
    "GraphicsPublishRequest": { "$ref": "#/$defs/GraphicsPublishRequest" },
    "GraphicsPublishResult": { "$ref": "#/$defs/GraphicsPublishResult" },
    "GraphicsRolloutRequest": { "$ref": "#/$defs/GraphicsRolloutRequest" },
    "GraphicsRolloutResult": { "$ref": "#/$defs/GraphicsRolloutResult" },
    "GraphicsRollbackRequest": { "$ref": "#/$defs/GraphicsRollbackRequest" },
    "GraphicsAuditEvent": { "$ref": "#/$defs/GraphicsAuditEvent" },
    "GraphicsWaiver": { "$ref": "#/$defs/GraphicsWaiver" },
    "GraphicsReleaseBlocker": { "$ref": "#/$defs/GraphicsReleaseBlocker" },
    "GraphicsReleaseLink": { "$ref": "#/$defs/GraphicsReleaseLink" },
    "GraphicsReleaseManifestRef": { "$ref": "#/$defs/GraphicsReleaseManifestRef" },
    "GraphicsChangeSet": { "$ref": "#/$defs/GraphicsChangeSet" },
    "ModuleGraphicsLineageGraph": { "$ref": "#/$defs/ModuleGraphicsLineageGraph" },
    "RuntimeGraphicsComplianceBeacon": { "$ref": "#/$defs/RuntimeGraphicsComplianceBeacon" },
    "RuntimeComplianceBeacon": { "$ref": "#/$defs/RuntimeGraphicsComplianceBeacon" },
    "VisualDebtObservatory": { "$ref": "#/$defs/VisualDebtObservatory" },
    "GraphicsEnvironmentPolicyPack": { "$ref": "#/$defs/GraphicsEnvironmentPolicyPack" },
    "GraphicsEvidencePlan": { "$ref": "#/$defs/GraphicsEvidencePlan" },
    "GraphicsReleaseDashboard": { "$ref": "#/$defs/GraphicsReleaseDashboard" },
    "multiSitePlantBrandingGovernance": {
      "type": "object",
      "additionalProperties": true
    },
    "controlledEmergencyOverridePath": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "DesignConfig": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "_meta": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "version": { "type": "string" },
            "updatedAt": { "type": "string" },
            "updatedBy": { "type": "string" },
            "authority": { "type": "string" },
            "localStorageAuthority": { "const": false }
          }
        }
      }
    },
    "TemplateRegistryEntry": {
      "type": "object",
      "required": [
        "templateId",
        "canonicalId",
        "version",
        "status",
        "owner",
        "moduleArchetype",
        "zones",
        "allowedZones",
        "allowedBlocks",
        "allowedBlocksByZone",
        "governedModules",
        "regulatedCompatibility",
        "shopfloorCompatibility",
        "defaultDensity",
        "supportedDensities",
        "themePolicy",
        "responsivePolicy",
        "qaEvidence",
        "updatedBy",
        "updatedAt",
        "evidenceRefs"
      ],
      "additionalProperties": true,
      "properties": {
        "templateId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]{1,120}$" },
        "canonicalId": { "type": "string" },
        "legacyCode": { "type": "string" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9_.-]+)?$" },
        "status": { "enum": ["draft-only", "controlled-draft", "validated", "publish-blocked", "published", "deprecated", "legacy-bridged"] },
        "registryStatus": { "enum": ["approved", "draft", "deprecated", "retired", "published", "controlled-draft"] },
        "owner": { "type": "string" },
        "moduleArchetype": { "type": "string" },
        "zones": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["zoneId", "type", "required"],
            "additionalProperties": true,
            "properties": {
              "zoneId": { "type": "string" },
              "type": { "type": "string" },
              "required": { "type": "boolean" }
            }
          }
        },
        "allowedBlocksByZone": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "allowedZones": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedBlocks": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          ]
        },
        "governedModules": { "type": "array", "items": { "type": "string" } },
        "regulatedCompatibility": { "type": "string" },
        "shopfloorCompatibility": { "type": "string" },
        "updatedBy": { "type": "string" },
        "updatedAt": { "type": "string" },
        "evidenceRefs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "defaultDensity": { "enum": ["compact", "default", "comfortable", "shopfloor"] },
        "supportedDensities": {
          "type": "array",
          "items": { "enum": ["compact", "default", "comfortable", "shopfloor"] }
        },
        "themePolicy": { "type": "object" },
        "responsivePolicy": { "type": "object" },
        "qaEvidence": { "type": "object" },
        "releaseManifestRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
        },
        "waiverIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "TemplateRegistryCollection": {
      "type": "object",
      "required": ["_meta", "templates"],
      "additionalProperties": true,
      "properties": {
        "_meta": { "type": "object" },
        "templates": {
          "type": "array",
          "items": { "$ref": "#/$defs/TemplateRegistryEntry" }
        }
      }
    },
    "TemplateDraft": {
      "allOf": [
        { "$ref": "#/$defs/TemplateRegistryEntry" },
        {
          "type": "object",
          "properties": {
            "_draft": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "savedAt": { "type": "string" },
                "savedBy": { "type": "string" },
                "baseRegistryVersion": { "type": "string" },
                "baseRegistryEtag": { "type": "string" }
              }
            }
          }
        }
      ]
    },
    "TemplateValidationResult": {
      "type": "object",
      "required": ["valid", "errors", "warnings", "checkedAt"],
      "properties": {
        "valid": { "type": "boolean" },
        "templateId": { "type": "string" },
        "checkedAt": { "type": "string" },
        "errors": { "type": "array", "items": { "type": "object" } },
        "warnings": { "type": "array", "items": { "type": "object" } }
      }
    },
    "GraphicsImpactReport": {
      "type": "object",
      "required": [
        "impactId",
        "analysisType",
        "affectedModules",
        "affectedRoutes",
        "affectedScreens",
        "affectedBlockFamilies",
        "regulatedModulesTouched",
        "shopfloorModulesTouched",
        "gatesToRerun",
        "blockers",
        "machineReadable"
      ],
      "properties": {
        "impactId": { "type": "string" },
        "analysisType": { "enum": ["token", "template", "component", "rollout", "change-set", "environment-policy", "policy-pack"] },
        "subject": { "type": "object" },
        "affectedModules": { "type": "array", "items": { "type": "object" } },
        "affectedRoutes": { "type": "array", "items": { "type": "string" } },
        "affectedScreens": { "type": "array", "items": { "type": "string" } },
        "affectedBlockFamilies": { "type": "array", "items": { "type": "string" } },
        "affectedTemplates": { "type": "array", "items": { "type": "string" } },
        "regulatedModulesTouched": { "type": "array", "items": { "type": "string" } },
        "shopfloorModulesTouched": { "type": "array", "items": { "type": "string" } },
        "gatesToRerun": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "object" } },
        "severityClass": { "enum": ["low", "medium", "high", "regulated", "shopfloor-critical"] },
        "requiredEvidence": { "type": "array", "items": { "$ref": "#/$defs/GraphicsEvidencePlan" } },
        "rerunPlan": { "type": "object", "additionalProperties": true },
        "rolloutScopes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "changeSetRef": { "type": "string" },
        "machineReadable": { "const": true },
        "blastRadius": { "type": "object", "additionalProperties": true },
        "recordedAt": { "type": "string" },
        "recordedBy": { "type": "string" },
        "expiresAt": { "type": "string" }
      }
    },
    "ModuleGraphicsComplianceEntry": {
      "type": "object",
      "required": ["moduleId", "templateId", "compliant", "findings", "status"],
      "additionalProperties": true,
      "properties": {
        "moduleId": { "type": "string" },
        "route": { "type": "string" },
        "templateId": { "type": "string" },
        "templateVersion": { "type": "string" },
        "regulated": { "type": "boolean" },
        "shopfloor": { "type": "boolean" },
        "screens": { "type": "array", "items": { "type": "string" } },
        "blockFamilies": { "type": "array", "items": { "type": "string" } },
        "findings": { "type": "array", "items": { "type": "object" } },
        "compliant": { "type": "boolean" },
        "status": { "enum": ["full-admin-controlled", "bridged-to-shared-tokens", "legacy-private-css", "blocked"] },
        "linkageStatus": { "enum": ["full-admin-controlled", "bridged-to-shared-tokens", "legacy-private-css", "blocked"] },
        "templateBindingSource": { "type": "string" },
        "sharedTokenCoverage": { "type": "number" },
        "sharedComponentCoverage": { "type": "number" },
        "bridgeAliasDebt": { "type": "integer" },
        "privateCssDebt": { "type": "integer" },
        "hardcodedStyleDebt": { "type": "integer" },
        "driftStatus": { "type": "string" },
        "blockerReason": { "type": "string" },
        "consumesHmComponents": { "type": "boolean" },
        "consumesSharedTokens": { "type": "boolean" },
        "usesPrivateCssShell": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "GraphicsDebtReport": {
      "type": "object",
      "required": ["debt", "summary"],
      "additionalProperties": true,
      "properties": {
        "debt": { "type": "object", "additionalProperties": true },
        "summary": { "type": "object", "additionalProperties": true }
      }
    },
    "GraphicsDriftReport": {
      "type": "object",
      "required": ["drift", "blockers"],
      "additionalProperties": true,
      "properties": {
        "drift": { "type": "object", "additionalProperties": true },
        "blockers": { "type": "array", "items": { "$ref": "#/$defs/GraphicsReleaseBlocker" } }
      }
    },
    "GraphicsPublishRequest": {
      "type": "object",
      "required": ["expectedVersion", "impactAnalysisId", "gateEvidence", "releaseManifestRefs"],
      "properties": {
        "expectedVersion": { "type": "string" },
        "templateId": { "type": "string" },
        "template": { "$ref": "#/$defs/TemplateDraft" },
        "impactAnalysisId": {
          "type": "string",
          "description": "Backend-recorded impactId that is still pending for the current registry state."
        },
        "blockersResolved": { "type": "boolean" },
        "gateEvidence": { "type": ["object", "array"] },
        "releaseManifestRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
        },
        "waiverIds": { "type": "array", "items": { "type": "string" } }
      }
    },
    "GraphicsPublishResult": {
      "type": "object",
      "required": ["publishId", "template", "registryVersion", "registryEtag", "status"],
      "properties": {
        "publishId": { "type": "string" },
        "status": { "const": "published" },
        "template": { "$ref": "#/$defs/TemplateRegistryEntry" },
        "validation": { "$ref": "#/$defs/TemplateValidationResult" },
        "impact": { "$ref": "#/$defs/GraphicsImpactReport" },
        "releaseManifestRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
        },
        "registryVersion": { "type": "string" },
        "registryEtag": { "type": "string" }
      }
    },
    "GraphicsRolloutRequest": {
      "type": "object",
      "required": ["expectedVersion", "impactType", "scope"],
      "additionalProperties": true,
      "properties": {
        "expectedVersion": { "type": "string" },
        "impactType": { "enum": ["token", "template", "component", "rollout", "policy-pack", "environment-policy"] },
        "scopeMode": { "enum": ["preview-only", "canary-module-group", "canary-domain", "environment-stage", "global-apply"] },
        "scope": { "type": "object", "additionalProperties": true },
        "policyPack": { "type": "string" },
        "environmentPolicyPack": { "type": "string" },
        "releaseManifestRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
        },
        "postCanaryVerification": {
          "type": "object",
          "required": ["runtimeBeaconRef", "driftReportRef", "moduleOwnerSignoffRef", "releaseManifestRefs"],
          "additionalProperties": true,
          "properties": {
            "runtimeBeaconRef": { "type": "string" },
            "driftReportRef": { "type": "string" },
            "moduleOwnerSignoffRef": { "type": "string" },
            "releaseManifestRefs": {
              "type": "array",
              "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
            }
          }
        },
        "rollbackPlan": { "type": "object", "additionalProperties": true }
      }
    },
    "GraphicsRolloutApplyRequest": {
      "type": "object",
      "required": ["expectedVersion", "rolloutId"],
      "additionalProperties": false,
      "properties": {
        "expectedVersion": { "type": "string" },
        "rolloutId": { "type": "string" },
        "postCanaryVerification": {
          "type": "object",
          "required": ["runtimeBeaconRef", "driftReportRef", "moduleOwnerSignoffRef", "releaseManifestRefs"],
          "additionalProperties": false,
          "properties": {
            "runtimeBeaconRef": { "type": "string" },
            "driftReportRef": { "type": "string" },
            "moduleOwnerSignoffRef": { "type": "string" },
            "releaseManifestRefs": {
              "type": "array",
              "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
            }
          }
        }
      }
    },
    "GraphicsRolloutResult": {
      "type": "object",
      "required": ["rollout", "registryVersion", "registryEtag"],
      "additionalProperties": true,
      "properties": {
        "rollout": { "type": "object", "additionalProperties": true },
        "registryVersion": { "type": "string" },
        "registryEtag": { "type": "string" }
      }
    },
    "GraphicsRollbackRequest": {
      "type": "object",
      "required": ["expectedVersion", "rolloutId"],
      "properties": {
        "expectedVersion": { "type": "string" },
        "rolloutId": { "type": "string" },
        "targetSnapshotId": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "GraphicsAuditEvent": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "event_type": { "type": "string" },
        "aggregate_type": { "const": "graphics_governance" },
        "aggregate_id": { "type": "string" },
        "actor_name": { "type": "string" },
        "payload": { "type": "object" },
        "metadata": { "type": "object" },
        "recorded_at": { "type": "string" }
      }
    },
    "GraphicsWaiver": {
      "type": "object",
      "required": ["scope", "targetId", "reason", "riskClass", "compensatingControl", "owner", "approver", "expiresAt"],
      "additionalProperties": true,
      "properties": {
        "waiverId": { "type": "string" },
        "scope": { "enum": ["template", "module", "component", "token", "release_gate", "graphics-governance"] },
        "targetId": { "type": "string" },
        "reason": { "type": "string" },
        "risk": { "type": "string" },
        "compensatingControl": { "type": "string" },
        "owner": { "type": "string" },
        "approver": { "type": "string" },
        "riskClass": { "enum": ["low", "medium", "high", "regulated", "shopfloor-critical"] },
        "status": { "enum": ["draft", "approved", "expired"] },
        "documentControlRefs": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
            ]
          }
        },
        "releaseManifestRefs": {
          "type": "array",
          "items": { "$ref": "#/$defs/GraphicsReleaseManifestRef" }
        },
        "expiresAt": { "type": "string" }
      }
    },
    "GraphicsReleaseBlocker": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "blockerId": { "type": "string" },
        "scope": { "type": "string" },
        "targetId": { "type": "string" },
        "moduleId": { "type": "string" },
        "templateId": { "type": "string" },
        "severity": { "enum": ["warning", "blocker", "waived"] },
        "status": { "enum": ["active", "waived", "pending-review"] },
        "reason": { "type": "string" },
        "releaseGate": { "type": "string" },
        "releaseBlocked": { "type": "boolean" },
        "waiverAllowed": { "type": "boolean" }
      }
    },
    "GraphicsReleaseLink": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "graphicsAuthorityRefs": { "type": "array", "items": { "type": "string" } },
        "templateRegistryVersion": { "type": "string" },
        "templateRegistryChecksum": { "type": "string" },
        "complianceMatrixRef": { "type": "string" },
        "impactAnalysisRef": { "type": "string" },
        "waiversRef": { "type": "string" },
        "runtimeBeaconRef": { "type": "string" },
        "debtObservatoryRef": { "type": "string" },
        "multiSitePlantBrandingGovernanceRef": { "type": "string" },
        "controlledEmergencyOverridePathRef": { "type": "string" },
        "rolloutDecisionRef": { "type": "string" },
        "rollbackPlanRef": { "type": "string" },
        "releaseBlocked": { "type": "boolean" },
        "blockerCount": { "type": "integer" },
        "driftReportGeneratedAt": { "type": "string" },
        "evidenceBundleRequirements": { "type": "array", "items": { "type": "string" } }
      }
    },
    "GraphicsEvidencePlan": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "evidenceType": { "type": "string" },
        "required": { "type": ["boolean", "string"] },
        "owner": { "type": "string" }
      }
    },
    "GraphicsChangeSet": {
      "type": "object",
      "required": ["changeSetId", "status", "impact", "rolloutScopePlan", "evidenceChecklist"],
      "additionalProperties": true,
      "properties": {
        "changeSetId": { "type": "string" },
        "status": { "enum": ["preview-only", "impact-recorded", "draft-saved", "validated", "staged", "publish-blocked", "applied", "rolled-back", "waived"] },
        "source": { "type": "string" },
        "edits": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "diffSummary": { "type": "object", "additionalProperties": true },
        "impact": { "$ref": "#/$defs/GraphicsImpactReport" },
        "risk": { "type": "object", "additionalProperties": true },
        "rolloutScopePlan": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "evidenceChecklist": { "type": "array", "items": { "$ref": "#/$defs/GraphicsEvidencePlan" } }
      }
    },
    "ModuleGraphicsLineageGraph": {
      "type": "object",
      "required": ["nodes", "edges", "summary"],
      "additionalProperties": true,
      "properties": {
        "nodes": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "edges": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "summary": { "type": "object", "additionalProperties": true },
        "authorityRefs": { "type": "object", "additionalProperties": true }
      }
    },
    "RuntimeGraphicsComplianceBeacon": {
      "type": "object",
      "required": ["beacons", "summary"],
      "additionalProperties": true,
      "properties": {
        "beacons": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "summary": { "type": "object", "additionalProperties": true }
      }
    },
    "VisualDebtObservatory": {
      "type": "object",
      "required": ["byModule", "summary"],
      "additionalProperties": true,
      "properties": {
        "byModule": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "byDomain": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "byTeam": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "byRoute": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "summary": { "type": "object", "additionalProperties": true }
      }
    },
    "GraphicsEnvironmentPolicyPack": {
      "type": "object",
      "required": ["environment", "tokenOverrides", "evidenceObligations"],
      "additionalProperties": true,
      "properties": {
        "environment": { "enum": ["office", "review", "admin", "shopfloor", "kiosk", "tv", "night-shift", "glare-dirty-screen", "glove-mode"] },
        "tokenOverrides": { "type": "object", "additionalProperties": true },
        "componentPolicy": { "type": "array", "items": { "type": "string" } },
        "evidenceObligations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "GraphicsReleaseDashboard": {
      "type": "object",
      "required": ["readiness", "blockers", "complianceSummary", "debtSummary", "rolloutSummary"],
      "additionalProperties": true,
      "properties": {
        "readiness": { "enum": ["ready", "blocked", "unknown"] },
        "blockers": { "type": "object", "additionalProperties": true },
        "waivers": { "type": "object", "additionalProperties": true },
        "complianceSummary": { "type": "object", "additionalProperties": true },
        "debtSummary": { "type": "object", "additionalProperties": true },
        "rolloutSummary": { "type": "object", "additionalProperties": true },
        "postApplyVerification": { "type": "object", "additionalProperties": true },
        "trendDashboard": { "type": "object", "additionalProperties": true },
        "emergencyOverridePath": { "type": "object", "additionalProperties": true },
        "generatedAt": { "type": "string" }
      }
    },
    "GraphicsReleaseManifestRef": {
      "type": "object",
      "required": ["refType", "refId"],
      "properties": {
        "refType": { "enum": ["document", "dcr", "evidence", "release_manifest", "test_report", "approval"] },
        "refId": { "type": "string" },
        "uri": { "type": "string" }
      }
    }
  }
}
