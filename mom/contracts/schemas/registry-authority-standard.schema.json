{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hesemeng.com/mom/contracts/schemas/registry-authority-standard.schema.json",
  "title": "HESEM Registry Authority Standard",
  "type": "object",
  "required": [
    "_meta",
    "standardsProfile",
    "authorityLayers",
    "tableGovernanceRequiredFields",
    "endpointGovernanceRequiredFields",
    "deletionPolicy",
    "aiOperatingRules",
    "qualityGates"
  ],
  "properties": {
    "_meta": {
      "type": "object",
      "required": [
        "version",
        "effectiveDate",
        "status",
        "description"
      ],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "effectiveDate": {
          "type": "string",
          "format": "date"
        },
        "status": {
          "const": "authoritative_policy"
        },
        "description": {
          "type": "string",
          "minLength": 40
        }
      },
      "additionalProperties": true
    },
    "standardsProfile": {
      "type": "object",
      "minProperties": 6,
      "additionalProperties": {
        "type": "object",
        "required": [
          "standard",
          "purpose",
          "url"
        ],
        "properties": {
          "standard": {
            "type": "string",
            "minLength": 2
          },
          "purpose": {
            "type": "string",
            "minLength": 20
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "additionalProperties": true
      }
    },
    "authorityLayers": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "layer",
          "sourceOfTruth",
          "mustProvide"
        ],
        "properties": {
          "layer": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "sourceOfTruth": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "mustProvide": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 2
            }
          }
        },
        "additionalProperties": true
      }
    },
    "tableGovernanceRequiredFields": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9]*$"
      }
    },
    "endpointGovernanceRequiredFields": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z][A-Za-z0-9]*$"
      }
    },
    "deletionPolicy": {
      "type": "object",
      "required": [
        "defaultMode",
        "hardDeleteAllowedOnlyWhen",
        "hardDeleteForbiddenForDomains"
      ],
      "properties": {
        "defaultMode": {
          "enum": [
            "archive_only",
            "soft_delete"
          ]
        },
        "hardDeleteAllowedOnlyWhen": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "hardDeleteForbiddenForDomains": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        }
      },
      "additionalProperties": true
    },
    "aiOperatingRules": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string",
        "minLength": 20
      }
    },
    "qualityGates": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        }
      }
    }
  },
  "additionalProperties": false
}
