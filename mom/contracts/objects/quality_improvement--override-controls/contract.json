{
  "version": "1.0",
  "canonicalResource": "quality_improvement.override-controls",
  "canonicalName": "override_controls",
  "displayName": "Override Controls",
  "purpose": "Govern temporary override, waiver, and release bypass decisions so exceptional shipments or process gates remain explicit, timeboxed, signed, and reviewable.",
  "ownerDomain": "quality_improvement",
  "objectRole": "lifecycle_owner",
  "ownerTeam": "operations_governance",
  "storage": {
    "primaryTable": "operational_override_controls",
    "primaryKey": "override_id",
    "statusField": "override_status",
    "childTables": [],
    "legacyTables": [
      "shipment_gate_overrides"
    ]
  },
  "identity": {
    "strategy": "subject_type+subject_id+control_code+approved_at",
    "naturalKeys": [
      "subject_type",
      "subject_id",
      "control_code",
      "approved_at"
    ]
  },
  "governance": {
    "usageZone": "governed_support",
    "gateType": "override_gate",
    "auditClass": "workflow_audit_trail",
    "continuousImprovementLoop": "gate_review",
    "retentionClass": "quality_record_7y",
    "evidenceRequirements": [
      "reason_code",
      "approval_reference",
      "electronic_signature"
    ],
    "kpiSignals": [
      "override_volume",
      "active_override_expiry_rate",
      "follow_up_closure_rate"
    ],
    "autoAuditChecks": [
      "same_gate_subject_must_not_have_duplicate_active_override",
      "revocation_and_closure_require_reason_trace",
      "closed_override_must_preserve_follow_up_outcome"
    ]
  },
  "workflow": {
    "implemented": true,
    "truthStatus": "implemented_runtime",
    "source": "OperationalOverrideService service-backed lifecycle",
    "stateModelKey": "operational_override_controls_service_runtime",
    "lifecycleMode": "service_backed_runtime",
    "states": [
      { "value": "active", "label": "Active", "labelEn": "Active", "allowedTransitionsFrom": [] },
      { "value": "expired", "label": "Expired", "labelEn": "Expired", "allowedTransitionsFrom": ["active"] },
      { "value": "revoked", "label": "Revoked", "labelEn": "Revoked", "allowedTransitionsFrom": ["active"] },
      { "value": "closed", "label": "Closed", "labelEn": "Closed", "allowedTransitionsFrom": ["active", "expired", "revoked"] }
    ],
    "commands": [
      { "command": "revoke", "targetState": "revoked", "description": "Revoke an active override before the exception remains valid.", "idempotencyScope": "resource+transition", "preconditions": ["reason_recorded"] },
      { "command": "expire", "targetState": "expired", "description": "Expire an active override at the governed end of its validity window.", "idempotencyScope": "resource+transition", "preconditions": ["reason_recorded"] },
      { "command": "close", "targetState": "closed", "description": "Close the override after follow-up and exception handling are completed.", "idempotencyScope": "resource+transition", "preconditions": ["reason_recorded"] }
    ]
  },
  "integration": {
    "upstreamObjects": [
      "commercial_customer.sales-orders",
      "inventory_logistics.shipments",
      "quality_improvement.oqc-inspections"
    ],
    "downstreamObjects": [
      "quality_improvement.improvement-actions"
    ],
    "keyRelationships": [
      "subject_id -> sales_orders.sales_order_id",
      "control_code -> shipment_releases.shipment_id"
    ],
    "events": [
      { "eventName": "active", "description": "Override was activated under governed approval." },
      { "eventName": "revoked", "description": "Override was revoked before continued use." },
      { "eventName": "expired", "description": "Override expired after its timebox ended." },
      { "eventName": "closed", "description": "Override was closed after follow-up completion." }
    ]
  },
  "runtimeExposure": {
    "status": "compatibility_alias_api",
    "canonicalApiPath": "/api/v1/governance/override-controls",
    "notes": [
      "The live runtime surface is /api/v1/governance/override-controls while canonical naming remains quality_improvement.override-controls."
    ]
  },
  "compatibility": {
    "legacyNames": [
      "shipment_gate_overrides"
    ],
    "notes": [
      "Shipment-gate override files remain compatibility history only; the governed business meaning is now explicit as override-controls."
    ]
  },
  "invariants": [
    "Only one active override may exist for the same governed gate subject and control code.",
    "Revocation, expiry, and closure must retain reason trace.",
    "Overrides must remain timeboxed and signed."
  ]
}
