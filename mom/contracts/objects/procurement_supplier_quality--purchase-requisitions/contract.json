      "cannot_source_without_approval",
      "requisition_should_trace_to_governed_demand",
      "cancelled_requisitions_must_preserve_reason"
    ]
  },
  "workflow": {
    "implemented": true,
    "truthStatus": "implemented_runtime",
    "source": "wave1_lifecycle_normalization + purchase_requisitions_requisition_status",
    "stateModelKey": "purchase_requisitions_requisition_status",
    "lifecycleMode": "guarded_transition_runtime",
    "states": [
      { "value": "draft", "label": "Draft", "labelEn": "Draft", "allowedTransitionsFrom": [] },
      { "value": "submitted", "label": "Submitted", "labelEn": "Submitted", "allowedTransitionsFrom": ["draft"] },
      { "value": "approved", "label": "Approved", "labelEn": "Approved", "allowedTransitionsFrom": ["submitted"] },
      { "value": "sourced", "label": "Sourced", "labelEn": "Sourced", "allowedTransitionsFrom": ["approved"] },
      { "value": "cancelled", "label": "Cancelled", "labelEn": "Cancelled", "allowedTransitionsFrom": ["draft", "submitted", "approved"] }
    ],
    "commands": [
      { "command": "submit", "targetState": "submitted", "description": "Submit a requisition for approval.", "idempotencyScope": "resource+transition" },
      { "command": "approve", "targetState": "approved", "description": "Approve requisition demand for sourcing.", "idempotencyScope": "resource+transition", "preconditions": ["approval_basis_recorded"] },
      { "command": "source", "targetState": "sourced", "description": "Mark the requisition as sourced into supplier execution.", "idempotencyScope": "resource+transition", "preconditions": ["supplier_commitment_or_po_exists"] },
      { "command": "cancel", "targetState": "cancelled", "description": "Cancel the requisition before sourcing finishes.", "idempotencyScope": "resource+transition" }
    ]
  },
  "integration": {
    "upstreamObjects": [
      "planning_production.job-orders",
      "planning_production.work-orders",
      "inventory_logistics.inventory-items"
