      "purchase_requisition_id -> supplier_purchase_orders.purchase_requisition_id"
    ],
    "events": [
      { "eventName": "submitted", "description": "Requisition entered formal approval review." },
      { "eventName": "approved", "description": "Requisition was approved for sourcing." },
      { "eventName": "sourced", "description": "Requisition demand was transferred into supplier execution." },
      { "eventName": "cancelled", "description": "Requisition was cancelled." }
    ]
  },
  "runtimeExposure": {
    "status": "compatibility_alias_api",
    "notes": [
      "The live runtime surface is purchasing.purchase_requisitions.* while canonical naming remains procurement_supplier_quality.purchase-requisitions."
