{
  "form_code": "FRM-651",
  "title": "Final Inspection Report",
  "title_vi": "Phiếu kiểm tra thành phẩm",
  "version": "V1",
  "category": "quality",
  "frequency": "per_event",
  "sop_ref": "SOP-605",
  "description": "Ghi nhận kết quả kiểm tra cuối cùng trước khi đóng gói và xuất hàng, bao gồm kiểm tra kích thước, ngoại quan và chức năng.",
  "roles_allowed": ["admin", "qa_manager", "qc_inspector", "quality_engineer"],
  "fields": [
    {"id": "inspection_date", "type": "date", "label": "Ngày kiểm tra", "label_en": "Inspection Date", "required": true, "default": "today"},
    {"id": "job_number", "type": "text", "label": "Số Job", "label_en": "Job Number", "required": true},
    {"id": "part_number", "type": "text", "label": "Mã chi tiết", "label_en": "Part Number", "required": true},
    {"id": "part_rev", "type": "text", "label": "Revision", "label_en": "Part Revision", "required": true},
    {"id": "part_name", "type": "text", "label": "Tên chi tiết", "label_en": "Part Name", "required": true},
    {"id": "customer", "type": "text", "label": "Khách hàng", "label_en": "Customer", "required": true},
    {"id": "po_number", "type": "text", "label": "Số PO", "label_en": "PO Number"},
    {"id": "lot_qty", "type": "number", "label": "Số lượng lô", "label_en": "Lot Quantity", "min": 1, "required": true},
    {"id": "sample_qty", "type": "number", "label": "Số lượng mẫu kiểm", "label_en": "Sample Quantity", "min": 1, "required": true},
    {
      "id": "sampling_plan",
      "type": "select",
      "label": "Kế hoạch lấy mẫu",
      "label_en": "Sampling Plan",
      "required": true,
      "options": [
        {"value": "100_pct", "label": "100%"},
        {"value": "aql_1.0", "label": "AQL 1.0"},
        {"value": "aql_2.5", "label": "AQL 2.5"},
        {"value": "aql_4.0", "label": "AQL 4.0"},
        {"value": "custom", "label": "Khác (Custom)"}
      ]
    },
    {
      "id": "dimensional_results",
      "type": "table",
      "label": "Kết quả đo kích thước",
      "label_en": "Dimensional Results",
      "min_rows": 1,
      "max_rows": 50,
      "columns": [
        {"id": "dim_id", "type": "text", "label": "Kích thước / Balloon #", "width": "15%", "required": true},
        {"id": "characteristic", "type": "text", "label": "Đặc tính", "width": "15%"},
        {"id": "nominal", "type": "text", "label": "Danh nghĩa", "width": "12%", "required": true},
        {"id": "tolerance", "type": "text", "label": "Dung sai", "width": "12%", "required": true},
        {"id": "actual", "type": "text", "label": "Giá trị đo", "width": "12%", "required": true},
        {"id": "gage_used", "type": "text", "label": "Dụng cụ đo", "width": "14%"},
        {"id": "result", "type": "select", "label": "Kết quả", "width": "12%", "options": [
          {"value": "pass", "label": "Đạt", "color": "#2f9e44"},
          {"value": "fail", "label": "NG", "color": "#e03131"}
        ]}
      ]
    },
    {
      "id": "visual_inspection",
      "type": "select",
      "label": "Kiểm tra ngoại quan",
      "label_en": "Visual Inspection",
      "required": true,
      "options": [
        {"value": "pass", "label": "Đạt (Pass)", "color": "#2f9e44"},
        {"value": "fail", "label": "Không đạt (Fail)", "color": "#e03131"}
      ]
    },
    {"id": "visual_notes", "type": "textarea", "label": "Ghi chú ngoại quan", "label_en": "Visual Notes", "rows": 2, "placeholder": "Mô tả lỗi ngoại quan nếu có (trầy, rỗ, ba via)..."},
    {
      "id": "surface_finish_check",
      "type": "select",
      "label": "Kiểm tra độ nhám bề mặt",
      "label_en": "Surface Finish Check",
      "options": [
        {"value": "pass", "label": "Đạt (Pass)", "color": "#2f9e44"},
        {"value": "fail", "label": "Không đạt (Fail)", "color": "#e03131"},
        {"value": "na", "label": "N/A", "color": "#868e96"}
      ]
    },
    {
      "id": "thread_gage_check",
      "type": "select",
      "label": "Kiểm tra ren (nếu có)",
      "label_en": "Thread Gage Check",
      "options": [
        {"value": "pass", "label": "Đạt (Pass)", "color": "#2f9e44"},
        {"value": "fail", "label": "Không đạt (Fail)", "color": "#e03131"},
        {"value": "na", "label": "N/A", "color": "#868e96"}
      ]
    },
    {"id": "qty_accepted", "type": "number", "label": "Số lượng đạt", "label_en": "Quantity Accepted", "min": 0, "required": true},
    {"id": "qty_rejected", "type": "number", "label": "Số lượng không đạt", "label_en": "Quantity Rejected", "min": 0, "required": true, "default": 0},
    {"id": "ncr_number", "type": "text", "label": "Số NCR (nếu có)", "label_en": "NCR Number", "placeholder": "VD: NCR-2026-001"},
    {
      "id": "disposition",
      "type": "select",
      "label": "Quyết định xử lý",
      "label_en": "Disposition",
      "required": true,
      "options": [
        {"value": "accept", "label": "Chấp nhận (Accept)", "color": "#2f9e44"},
        {"value": "reject", "label": "Từ chối (Reject)", "color": "#e03131"},
        {"value": "rework", "label": "Làm lại (Rework)", "color": "#e67700"},
        {"value": "concession", "label": "Chấp nhận có điều kiện (Concession)", "color": "#1971c2"},
        {"value": "scrap", "label": "Phế phẩm (Scrap)", "color": "#e03131"}
      ]
    },
    {"id": "inspected_by", "type": "text", "label": "Người kiểm tra", "label_en": "Inspected By", "required": true},
    {"id": "approved_by", "type": "text", "label": "Người phê duyệt", "label_en": "Approved By"},
    {"id": "notes", "type": "textarea", "label": "Ghi chú", "label_en": "Notes", "rows": 3}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "notifications": {
    "on_reject": ["qa_manager", "production_manager"],
    "on_submit": ["qa_manager"]
  }
}
