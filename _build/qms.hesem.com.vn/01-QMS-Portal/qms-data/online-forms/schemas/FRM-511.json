{
  "form_code": "FRM-511",
  "title": "Setup & First-Piece Record",
  "title_vi": "Phiếu cài đặt máy & kiểm tra chi tiết đầu tiên",
  "version": "V1",
  "category": "production",
  "frequency": "per_event",
  "sop_ref": "SOP-504",
  "description": "Ghi nhận thông số cài đặt máy, kết quả kiểm tra chi tiết đầu tiên trước khi chạy sản xuất hàng loạt.",
  "roles_allowed": ["admin", "production_manager", "shift_leader", "cnc_operator", "qc_inspector"],
  "fields": [
    {"id": "setup_date", "type": "date", "label": "Ngày", "label_en": "Date", "required": true, "default": "today"},
    {"id": "machine_id", "type": "text", "label": "Mã máy", "label_en": "Machine ID", "required": true, "placeholder": "VD: CNC-01"},
    {"id": "job_number", "type": "text", "label": "Số Job", "label_en": "Job Number", "required": true},
    {"id": "part_number", "type": "text", "label": "Mã chi tiết", "label_en": "Part Number", "required": true},
    {"id": "part_rev", "type": "text", "label": "Revision", "label_en": "Part Revision", "required": true},
    {"id": "operation_no", "type": "text", "label": "Nguyên công", "label_en": "Operation No.", "required": true, "placeholder": "VD: OP10, OP20"},
    {"id": "shift", "type": "select", "label": "Ca", "label_en": "Shift", "required": true, "options": [
      {"value": "1", "label": "Ca 1"},
      {"value": "2", "label": "Ca 2"},
      {"value": "3", "label": "Ca 3"}
    ]},
    {"id": "program_number", "type": "text", "label": "Số chương trình CNC", "label_en": "CNC Program No.", "required": true},
    {"id": "program_rev", "type": "text", "label": "Revision chương trình", "label_en": "Program Revision"},
    {
      "id": "tooling",
      "type": "table",
      "label": "Danh sách dao/dụng cụ",
      "label_en": "Tooling List",
      "min_rows": 1,
      "max_rows": 30,
      "columns": [
        {"id": "tool_position", "type": "text", "label": "Vị trí dao", "width": "15%", "required": true},
        {"id": "tool_description", "type": "text", "label": "Mô tả dao", "width": "30%", "required": true},
        {"id": "tool_offset", "type": "text", "label": "Offset", "width": "20%"},
        {"id": "wear_offset", "type": "text", "label": "Wear Offset", "width": "15%"},
        {"id": "condition", "type": "select", "label": "Tình trạng", "width": "20%", "options": [
          {"value": "new", "label": "Mới"},
          {"value": "ok", "label": "Còn tốt"},
          {"value": "replace_soon", "label": "Sắp thay"}
        ]}
      ]
    },
    {
      "id": "work_holding",
      "type": "text",
      "label": "Đồ gá / kẹp",
      "label_en": "Work Holding / Fixture",
      "required": true,
      "placeholder": "VD: Vise 6\", Fixture F-101"
    },
    {
      "id": "first_piece_dimensions",
      "type": "table",
      "label": "Kết quả đo chi tiết đầu tiên",
      "label_en": "First-Piece Measurements",
      "min_rows": 1,
      "max_rows": 30,
      "columns": [
        {"id": "dimension_id", "type": "text", "label": "Kích thước / Đặc tính", "width": "20%", "required": true},
        {"id": "nominal", "type": "text", "label": "Giá trị danh nghĩa", "width": "15%", "required": true},
        {"id": "tolerance", "type": "text", "label": "Dung sai", "width": "15%", "required": true},
        {"id": "actual", "type": "text", "label": "Giá trị đo", "width": "15%", "required": true},
        {"id": "gage_used", "type": "text", "label": "Dụng cụ đo", "width": "15%"},
        {"id": "result", "type": "select", "label": "Kết quả", "width": "12%", "options": [
          {"value": "pass", "label": "Đạt", "color": "#2f9e44"},
          {"value": "fail", "label": "Không đạt", "color": "#e03131"}
        ]}
      ]
    },
    {
      "id": "visual_check",
      "type": "select",
      "label": "Kiểm tra ngoại quan",
      "label_en": "Visual Check",
      "required": true,
      "options": [
        {"value": "pass", "label": "Đạt (Pass)", "color": "#2f9e44"},
        {"value": "fail", "label": "Không đạt (Fail)", "color": "#e03131"}
      ]
    },
    {
      "id": "overall_result",
      "type": "select",
      "label": "Kết quả tổng thể",
      "label_en": "Overall Result",
      "required": true,
      "options": [
        {"value": "approved", "label": "Chấp nhận chạy (Approved)", "color": "#2f9e44"},
        {"value": "rework", "label": "Cần điều chỉnh lại (Rework)", "color": "#e67700"},
        {"value": "rejected", "label": "Từ chối (Rejected)", "color": "#e03131"}
      ]
    },
    {"id": "setup_by", "type": "text", "label": "Người cài đặt", "label_en": "Setup By", "required": true},
    {"id": "verified_by", "type": "text", "label": "Người xác nhận", "label_en": "Verified By", "required": true},
    {"id": "setup_start_time", "type": "time", "label": "Giờ bắt đầu setup", "label_en": "Setup Start Time", "required": true},
    {"id": "setup_end_time", "type": "time", "label": "Giờ kết thúc setup", "label_en": "Setup End Time", "required": true},
    {"id": "notes", "type": "textarea", "label": "Ghi chú", "label_en": "Notes", "rows": 3, "placeholder": "Các lưu ý đặc biệt cho setup này..."}
  ],
  "auto_fields": ["submitted_by", "submitted_at", "entry_id"],
  "computed_fields": [
    {"id": "setup_duration_minutes", "formula": "time_diff(setup_start_time, setup_end_time)", "label": "Thời gian setup (phút)"}
  ],
  "notifications": {
    "on_reject": ["production_manager", "shift_leader"],
    "on_submit": ["production_manager"]
  }
}
