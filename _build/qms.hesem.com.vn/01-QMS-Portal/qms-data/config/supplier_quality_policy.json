{
  "_meta": {
    "version": "1.0",
    "created": "2026-03-31",
    "description": "Supplier quality management policy governing ASL qualification, performance scoring, incoming inspection, skip-lot programs, and SCAR management"
  },
  "scorecard": {
    "weights": {
      "quality": { "label": "Quality", "label_vi": "Chat luong", "weight": 0.40, "metric": "lot_acceptance_rate" },
      "delivery": { "label": "Delivery", "label_vi": "Giao hang", "weight": 0.25, "metric": "on_time_delivery_rate" },
      "responsiveness": { "label": "Responsiveness", "label_vi": "Phan hoi", "weight": 0.15, "metric": "avg_response_days" },
      "documentation": { "label": "Documentation", "label_vi": "Tai lieu", "weight": 0.10, "metric": "doc_compliance_rate" },
      "cost": { "label": "Cost Competitiveness", "label_vi": "Canh tranh gia", "weight": 0.10, "metric": "price_variance_percent" }
    },
    "thresholds": {
      "preferred": { "label": "Preferred", "label_vi": "Uu tien", "min_score": 90, "color": "#22c55e", "review_months": 12 },
      "approved": { "label": "Approved", "label_vi": "Duoc phe duyet", "min_score": 70, "color": "#3b82f6", "review_months": 6 },
      "conditional": { "label": "Conditional", "label_vi": "Co dieu kien", "min_score": 50, "color": "#f59e0b", "review_months": 3 },
      "probation": { "label": "Probation", "label_vi": "Thu viec", "min_score": 30, "color": "#ef4444", "review_months": 1 },
      "disqualified": { "label": "Disqualified", "label_vi": "Loai bo", "min_score": 0, "color": "#6b7280", "review_months": null }
    },
    "scoring_period_months": 12,
    "rolling_window": true
  },
  "skip_lot_program": {
    "standard": "ANSI/ASQ Z1.4",
    "general_inspection_level": "II",
    "switching_rules": {
      "normal_to_tightened": {
        "label": "Normal to Tightened",
        "label_vi": "Binh thuong sang siet chat",
        "trigger": "2_of_5_lots_rejected",
        "description": "Switch to tightened when 2 out of 5 consecutive lots are rejected"
      },
      "tightened_to_normal": {
        "label": "Tightened to Normal",
        "label_vi": "Siet chat sang binh thuong",
        "trigger": "5_consecutive_lots_accepted",
        "description": "Return to normal after 5 consecutive lots accepted under tightened inspection"
      },
      "normal_to_reduced": {
        "label": "Normal to Reduced (Skip-Lot)",
        "label_vi": "Binh thuong sang giam (Bo lo)",
        "trigger": "10_consecutive_lots_accepted",
        "additional_conditions": ["supplier_score_gte_90", "production_at_steady_state", "qa_manager_approval"],
        "description": "Switch to reduced/skip-lot after 10 consecutive lots accepted with preferred supplier score"
      },
      "reduced_to_normal": {
        "label": "Reduced to Normal",
        "label_vi": "Giam sang binh thuong",
        "trigger": "1_lot_rejected",
        "description": "Return to normal immediately upon any lot rejection under reduced inspection"
      },
      "tightened_discontinue": {
        "label": "Discontinue Acceptance",
        "label_vi": "Ngung chap nhan",
        "trigger": "5_consecutive_lots_rejected_under_tightened",
        "description": "Discontinue acceptance and require supplier corrective action if 5 lots rejected under tightened"
      }
    },
    "skip_lot_frequencies": {
      "skip_2": { "label": "Inspect 1 of 2", "label_vi": "Kiem 1 trong 2", "inspect_ratio": 0.50 },
      "skip_3": { "label": "Inspect 1 of 3", "label_vi": "Kiem 1 trong 3", "inspect_ratio": 0.33 },
      "skip_5": { "label": "Inspect 1 of 5", "label_vi": "Kiem 1 trong 5", "inspect_ratio": 0.20 },
      "dock_to_stock": { "label": "Dock to Stock", "label_vi": "Nhap thang kho", "inspect_ratio": 0.00, "requires": ["preferred_supplier", "certificate_verification_only"] }
    }
  },
  "asl_management": {
    "review_frequency": {
      "preferred": { "months": 12, "reviewer_role": "supply_chain_manager" },
      "approved": { "months": 6, "reviewer_role": "supply_chain_manager" },
      "conditional": { "months": 3, "reviewer_role": "qa_manager" },
      "probation": { "months": 1, "reviewer_role": "qa_manager" }
    },
    "qualification_requirements": {
      "initial": [
        { "key": "supplier_survey", "label": "Supplier Quality Survey", "label_vi": "Khao sat chat luong NCC", "required": true },
        { "key": "quality_certs", "label": "Quality System Certificates (AS9100, ISO 9001, Nadcap)", "label_vi": "Chung chi HTQL (AS9100, ISO 9001, Nadcap)", "required": true },
        { "key": "first_article", "label": "First Article Approval", "label_vi": "Phe duyet mau dau tien", "required": true },
        { "key": "capability_review", "label": "Process Capability Review", "label_vi": "Xem xet nang luc quy trinh", "required": true },
        { "key": "financial_check", "label": "Financial Stability Check", "label_vi": "Kiem tra on dinh tai chinh", "required": false },
        { "key": "on_site_audit", "label": "On-Site Audit", "label_vi": "Danh gia tai cho", "required": false, "conditional": "special_process_supplier" }
      ],
      "requalification": [
        { "key": "scorecard_review", "label": "Performance Scorecard Review", "label_vi": "Xem xet the diem hieu suat", "required": true },
        { "key": "cert_validity", "label": "Certificate Validity Check", "label_vi": "Kiem tra hieu luc chung chi", "required": true },
        { "key": "scar_history", "label": "SCAR History Review", "label_vi": "Xem xet lich su SCAR", "required": true }
      ]
    }
  },
  "scar_policy": {
    "prefix": "SCAR",
    "format": "SCAR-{YYYY}-{NNNN}",
    "sla_timelines": {
      "initial_response_days": 5,
      "containment_action_days": 7,
      "root_cause_analysis_days": 15,
      "corrective_action_plan_days": 30,
      "effectiveness_verification_days": 90,
      "full_closure_days": 45
    },
    "escalation_rules": [
      {
        "trigger": "no_response_after_initial_sla",
        "action": "escalate_to_supplier_management",
        "label": "No Response Escalation",
        "label_vi": "Leo thang khong phan hoi"
      },
      {
        "trigger": "repeat_scar_same_issue_within_6_months",
        "action": "downgrade_supplier_status",
        "label": "Repeat Issue Downgrade",
        "label_vi": "Ha cap do loi lap lai"
      },
      {
        "trigger": "3_open_scars_simultaneously",
        "action": "supplier_on_probation",
        "label": "Multiple SCAR Probation",
        "label_vi": "Thu viec nhieu SCAR"
      }
    ],
    "severity_levels": {
      "minor": { "label": "Minor", "label_vi": "Nhe", "response_days": 10, "requires_8d": false },
      "major": { "label": "Major", "label_vi": "Lon", "response_days": 5, "requires_8d": true },
      "critical": { "label": "Critical", "label_vi": "Nghiem trong", "response_days": 3, "requires_8d": true }
    }
  },
  "incoming_inspection": {
    "default_aql": {
      "critical": 0,
      "major": 1.0,
      "minor": 2.5
    },
    "sampling_levels": {
      "level_I": { "label": "Reduced", "label_vi": "Giam", "use_for": "preferred_suppliers_reduced_inspection" },
      "level_II": { "label": "Normal", "label_vi": "Binh thuong", "use_for": "standard_incoming" },
      "level_III": { "label": "Tightened", "label_vi": "Siet chat", "use_for": "new_or_problem_suppliers" },
      "level_S1": { "label": "Special S-1", "label_vi": "Dac biet S-1", "use_for": "destructive_testing" },
      "level_S2": { "label": "Special S-2", "label_vi": "Dac biet S-2", "use_for": "expensive_destructive_testing" }
    },
    "required_documentation": [
      { "key": "coc", "label": "Certificate of Conformance", "label_vi": "Giay chung nhan phu hop", "always_required": true },
      { "key": "coa", "label": "Certificate of Analysis", "label_vi": "Giay chung nhan phan tich", "always_required": false, "required_for": ["raw_material", "chemical"] },
      { "key": "material_cert", "label": "Material Test Report", "label_vi": "Bao cao thu nghiem vat lieu", "always_required": false, "required_for": ["raw_material"] },
      { "key": "nadcap_cert", "label": "Nadcap Process Certificate", "label_vi": "Chung chi quy trinh Nadcap", "always_required": false, "required_for": ["special_process"] },
      { "key": "dimensional_report", "label": "Dimensional Inspection Report", "label_vi": "Bao cao kiem tra kich thuoc", "always_required": false, "required_for": ["finished_part", "first_article"] }
    ]
  }
}
