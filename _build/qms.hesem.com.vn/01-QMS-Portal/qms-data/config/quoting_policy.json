  "overhead_defaults": {
    "shop_overhead_percent": 35,
    "general_admin_percent": 12,
    "engineering_nre_rate_per_hour": 90,
    "programming_rate_per_hour": 85,
    "quality_overhead_percent": 8,
    "packaging_handling_percent": 3,
    "freight_default": "fob_origin",
    "fai_flat_charge_usd": 500,
    "nre_charge_applicable": ["engineer_to_order", "prototype", "first_article"]
