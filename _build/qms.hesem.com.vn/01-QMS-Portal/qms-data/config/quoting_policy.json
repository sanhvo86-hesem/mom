{
  "_meta": {
    "version": "1.0",
    "created": "2026-03-31",
    "description": "Quoting and estimation policy for CNC aerospace manufacturing, defining margin targets, machine rates, overhead calculations, and win/loss tracking"
  },
  "quote_format": "QUO-{YYYY}-{NNNN}",
  "validity_period_days": 30,
  "revision_tracking": true,
  "margin_targets": {
    "by_customer_type": {
      "prime_oem": {
        "label": "Prime / OEM",
        "label_vi": "Khach hang chinh / OEM",
        "target_margin_percent": 18,
        "min_margin_percent": 12,
        "approval_below_min": "ceo"
      },
      "tier_1": {
        "label": "Tier 1 Supplier",
        "label_vi": "NCC cap 1",
        "target_margin_percent": 22,
        "min_margin_percent": 15,
        "approval_below_min": "sales_manager"
      },
      "tier_2": {
        "label": "Tier 2 Supplier",
        "label_vi": "NCC cap 2",
        "target_margin_percent": 25,
        "min_margin_percent": 18,
        "approval_below_min": "sales_manager"
      },
      "mro": {
        "label": "MRO / Aftermarket",
        "label_vi": "MRO / Hau mai",
        "target_margin_percent": 30,
        "min_margin_percent": 20,
        "approval_below_min": "sales_manager"
      },
      "defense": {
        "label": "Defense / Government",
        "label_vi": "Quoc phong / Chinh phu",
        "target_margin_percent": 15,
        "min_margin_percent": 10,
        "approval_below_min": "ceo"
      },
      "commercial": {
        "label": "Commercial / Industrial",
        "label_vi": "Thuong mai / Cong nghiep",
        "target_margin_percent": 28,
        "min_margin_percent": 20,
        "approval_below_min": "sales_manager"
      }
    },
    "by_order_type": {
      "prototype": { "label": "Prototype", "label_vi": "Mau thu", "margin_adder_percent": 10 },
      "first_article": { "label": "First Article", "label_vi": "Mau dau tien", "margin_adder_percent": 5 },
      "repeat_order": { "label": "Repeat Order", "label_vi": "Don hang lap lai", "margin_adder_percent": 0 },
      "blanket_order": { "label": "Blanket / LTA", "label_vi": "Don hang khung / LTA", "margin_adder_percent": -3 }
    }
  },
  "material_cost_calculation": {
    "methods": {
      "last_purchase_price": { "label": "Last Purchase Price", "label_vi": "Gia mua gan nhat", "default": true },
      "weighted_average": { "label": "Weighted Average", "label_vi": "Binh quan gia quyen" },
      "supplier_quote": { "label": "Current Supplier Quote", "label_vi": "Bao gia NCC hien tai" },
      "market_index": { "label": "Market Index", "label_vi": "Chi so thi truong" }
    },
    "waste_factor_percent": 15,
    "minimum_order_charge": true,
    "material_handling_percent": 3,
    "certifications_surcharge": {
      "mil_spec": { "label": "MIL-SPEC Material", "label_vi": "Vat lieu MIL-SPEC", "surcharge_percent": 8 },
      "aerospace_grade": { "label": "Aerospace Grade", "label_vi": "Cap hang khong", "surcharge_percent": 5 },
      "nadcap_heat_lot": { "label": "Nadcap Heat Lot", "label_vi": "Lo nhiet Nadcap", "surcharge_percent": 10 }
    }
  },
