  "quantity_breaks": {
    "enabled": true,
    "default_breaks": [1, 5, 10, 25, 50, 100, 250, 500],
    "setup_amortization": true,
    "learning_curve_factor": {
      "enabled": true,
      "initial_rate": 1.0,
      "reduction_per_doubling": 0.10,
      "floor": 0.70
    }
  },
  "win_loss_tracking": {
    "enabled": true,
    "categories": {
      "won": { "label": "Won", "label_vi": "Thang", "color": "#22c55e" },
      "lost_price": { "label": "Lost - Price", "label_vi": "Thua - Gia", "color": "#ef4444" },
      "lost_delivery": { "label": "Lost - Delivery", "label_vi": "Thua - Giao hang", "color": "#f59e0b" },
      "lost_capability": { "label": "Lost - Capability", "label_vi": "Thua - Nang luc", "color": "#8b5cf6" },
      "lost_relationship": { "label": "Lost - Relationship", "label_vi": "Thua - Quan he", "color": "#6b7280" },
      "lost_quality": { "label": "Lost - Quality History", "label_vi": "Thua - Lich su chat luong", "color": "#dc2626" },
      "no_bid": { "label": "No Bid", "label_vi": "Khong bao gia", "color": "#9ca3af" },
      "cancelled": { "label": "Cancelled by Customer", "label_vi": "Khach hang huy", "color": "#64748b" },
      "pending": { "label": "Pending Decision", "label_vi": "Cho quyet dinh", "color": "#3b82f6" }
    },
    "follow_up_days": 14,
    "review_frequency_months": 3
  },
  "approval_workflow": {
    "below_5000_usd": { "approver_role": "estimator", "label": "Small Quote", "label_vi": "Bao gia nho" },
    "5000_to_25000_usd": { "approver_role": "sales_manager", "label": "Standard Quote", "label_vi": "Bao gia tieu chuan" },
    "25000_to_100000_usd": { "approver_role": "production_director", "label": "Large Quote", "label_vi": "Bao gia lon" },
    "above_100000_usd": { "approver_role": "ceo", "label": "Strategic Quote", "label_vi": "Bao gia chien luoc" },
    "below_minimum_margin": { "approver_role": "ceo", "label": "Below Minimum Margin", "label_vi": "Duoi bien loi nhuan toi thieu" }
  }
}
